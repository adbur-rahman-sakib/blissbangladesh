<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Events | Bliss Bangladesh</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
  <style>
    .events-page { min-height: 100vh; background: #F8FAFC; }
    .events-hero { background: #0040A5; padding: 64px 60px 48px; text-align: center; }
    .events-hero h1 { font-family: 'Outfit', sans-serif; font-size: 2.6rem; font-weight: 800; color: #fff; margin-bottom: 12px; }
    .events-hero p { color: rgba(255,255,255,0.85); font-size: 1.05rem; font-family: 'Inter', sans-serif; }
    .events-body { max-width: 1100px; margin: 0 auto; padding: 56px 24px; }
    .events-filter { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 40px; }
    .filter-chip { padding: 6px 18px; border-radius: 20px; border: 1.5px solid #E2E8F0; background: #fff; color: #64748B; font-family: 'Inter', sans-serif; font-size: 0.85rem; font-weight: 500; cursor: pointer; transition: all 0.2s; }
    .filter-chip.active, .filter-chip:hover { border-color: #0040A5; background: #0040A5; color: #fff; }
    .events-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 28px; }
    .event-card { background: #fff; border-radius: 14px; border: 1px solid #E2E8F0; overflow: hidden; box-shadow: 0 2px 12px rgba(0,0,0,0.05); transition: transform 0.2s, box-shadow 0.2s; display: flex; flex-direction: column; }
    .event-card:hover { transform: translateY(-3px); box-shadow: 0 8px 28px rgba(0,64,165,0.1); }
    .event-card-img { width: 100%; height: 200px; background: #EEF4FF; display: flex; align-items: center; justify-content: center; overflow: hidden; }
    .event-card-img img { max-width: 100%; max-height: 200px; object-fit: contain; display: block; pointer-events: none; user-select: none; -webkit-user-drag: none; }
    .event-card-img-placeholder { width: 100%; height: 180px; background: linear-gradient(135deg,#EEF4FF,#DBEAFE); display: flex; align-items: center; justify-content: center; }
    .event-card-img-placeholder svg { opacity: 0.35; }
    .event-card-body { padding: 20px 22px; flex: 1; display: flex; flex-direction: column; }
    .event-category-badge { display: inline-block; padding: 3px 12px; border-radius: 12px; font-size: 0.72rem; font-weight: 600; letter-spacing: 0.5px; text-transform: uppercase; margin-bottom: 10px; }
    .cat-vaccination    { background: #DBEAFE; color: #1D4ED8; }
    .cat-health-camp    { background: #D1FAE5; color: #065F46; }
    .cat-seminar        { background: #FEF3C7; color: #92400E; }
    .cat-workshop       { background: #F3E8FF; color: #6B21A8; }
    .cat-community      { background: #FFE4E6; color: #9F1239; }
    .cat-general        { background: #F1F5F9; color: #475569; }
    .event-card-title { font-family: 'Outfit', sans-serif; font-size: 1.1rem; font-weight: 700; color: #0F172A; margin-bottom: 8px; line-height: 1.35; }
    .event-card-meta { display: flex; flex-direction: column; gap: 4px; margin-bottom: 16px; }
    .event-meta-row { display: flex; align-items: center; gap: 7px; font-family: 'Inter', sans-serif; font-size: 0.82rem; color: #64748B; }
    .event-meta-row svg { flex-shrink: 0; }
    .event-card-cta { margin-top: auto; display: inline-flex; align-items: center; gap: 6px; color: #0040A5; font-family: 'Inter', sans-serif; font-size: 0.88rem; font-weight: 600; text-decoration: none; }
    .event-card-cta:hover { color: #002d80; }
    .events-empty { text-align: center; padding: 80px 20px; color: #64748B; font-family: 'Inter', sans-serif; }
    .events-empty svg { margin-bottom: 16px; opacity: 0.3; }
    .page-nav { background: #fff; border-bottom: 1px solid #E2E8F0; padding: 0 60px; }
    .page-nav-inner { max-width: 1100px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; height: 64px; }
    .page-nav-brand { font-family: 'Outfit', sans-serif; font-weight: 800; font-size: 1.15rem; color: #0040A5; text-decoration: none; }
    .page-nav-links { display: flex; gap: 28px; }
    .page-nav-links a { font-family: 'Inter', sans-serif; font-size: 0.9rem; color: #475569; text-decoration: none; font-weight: 500; }
    .page-nav-links a:hover, .page-nav-links a.active { color: #0040A5; }
    .has-pdf-badge { display: inline-flex; align-items: center; gap: 4px; font-size: 0.72rem; font-weight: 600; color: #E53935; background: #FFF1F0; padding: 2px 8px; border-radius: 8px; margin-left: 8px; }
    @media (max-width: 600px) {
      .events-hero { padding: 40px 20px 32px; }
      .events-hero h1 { font-size: 1.8rem; }
      .events-body { padding: 32px 16px; }
      .page-nav { padding: 0 20px; }
    }
  </style>
</head>
<body class="events-page">

  <nav class="page-nav">
    <div class="page-nav-inner">
      <a href="/" class="page-nav-brand">Bliss Bangladesh</a>
      <div class="page-nav-links">
        <a href="/">Home</a>
        <a href="/#services">Services</a>
        <a href="/#schedules">Schedules</a>
        <a href="/events" class="active">Events</a>
        <a href="/#contact">Contact</a>
      </div>
    </div>
  </nav>

  <div class="events-hero">
    <h1>Upcoming Events</h1>
    <p>Health camps, vaccination drives, seminars, and community programs by Bliss Bangladesh.</p>
  </div>

  <div class="events-body">
    <%
      const categories = ['All', ...new Set(events.map(e => e.category))];
    %>
    <div class="events-filter" id="eventsFilter">
      <% categories.forEach(cat => { %>
        <button class="filter-chip <%= cat === 'All' ? 'active' : '' %>" data-cat="<%= cat %>"><%= cat %></button>
      <% }) %>
    </div>

    <% if (events.length === 0) { %>
      <div class="events-empty">
        <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="#0040A5" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        <h3 style="font-family:Outfit,sans-serif;color:#0F172A;margin-bottom:8px;">No Events Yet</h3>
        <p>Check back soon for upcoming health programs and community events.</p>
      </div>
    <% } else { %>
      <div class="events-grid" id="eventsGrid">
        <% events.forEach(event => { %>
          <%
            const catClass = {
              'Vaccination Drive': 'cat-vaccination',
              'Health Camp': 'cat-health-camp',
              'Seminar': 'cat-seminar',
              'Workshop': 'cat-workshop',
              'Community Outreach': 'cat-community',
            }[event.category] || 'cat-general';
            const dateStr = new Date(event.event_date).toLocaleDateString('en-GB', { day:'numeric', month:'long', year:'numeric' });
          %>
          <div class="event-card" data-category="<%= event.category %>">
            <% if (event.cover_image) { %>
              <div class="event-card-img" oncontextmenu="return false"><img src="<%= event.cover_image %>" alt="<%= event.title %>" draggable="false"></div>
            <% } else { %>
              <div class="event-card-img-placeholder">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#0040A5" stroke-width="1.2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              </div>
            <% } %>
            <div class="event-card-body">
              <div>
                <span class="event-category-badge <%= catClass %>"><%= event.category %></span>
                <% if (event.pdf_path) { %><span class="has-pdf-badge"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg> PDF</span><% } %>
              </div>
              <h3 class="event-card-title"><%= event.title %></h3>
              <div class="event-card-meta">
                <div class="event-meta-row">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                  <span><%= dateStr %><% if(event.event_time) { %> · <%= event.event_time %><% } %></span>
                </div>
                <% if (event.location) { %>
                <div class="event-meta-row">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                  <span><%= event.location %></span>
                </div>
                <% } %>
              </div>
              <a href="/events/<%= event.id %>" class="event-card-cta">
                View Details
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

  <script>
    document.querySelectorAll('#eventsFilter .filter-chip').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.filter-chip').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const cat = btn.dataset.cat;
        document.querySelectorAll('#eventsGrid .event-card').forEach(card => {
          card.style.display = (cat === 'All' || card.dataset.category === cat) ? '' : 'none';
        });
      });
    });
  </script>
</body>
</html>
