<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard | Bliss Bangladesh</title>
  
  <!-- Modern Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  
  <!-- CSS Stylesheets -->
  <link rel="stylesheet" href="/styles.css"> <!-- Base styles reset -->
  <link rel="stylesheet" href="/admin.css"> <!-- Admin portal UI styles -->
</head>
<body class="admin-dashboard-body">

  <div class="admin-dashboard-layout">
    
    <!-- Sidebar -->
    <aside class="admin-sidebar">
      <div class="sidebar-brand">
        <svg viewBox="0 0 48 48" width="32" height="32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M24 44C35.0457 44 44 35.0457 44 24C44 12.9543 35.0457 4 24 4C12.9543 4 4 12.9543 4 24C4 35.0457 12.9543 44 24 44Z" fill="#F8FAFC" />
          <path d="M24 16.5C24 16.5 20.5 13 18.5 15C16.5 17 17.5 20.5 20.5 23L24 26L27.5 23C30.5 20.5 31.5 17 29.5 15C27.5 13 24 16.5 24 16.5Z" fill="#E53935" />
          <path d="M12 28C14.5 33 20 36 24 36C28 36 33.5 33 36 28C36 28 32.5 30.5 28.5 28C24.5 25.5 23.5 25.5 19.5 28C15.5 30.5 12 28 12 28Z" fill="#0040A5" />
          <circle cx="24" cy="11" r="3" fill="#0040A5" />
        </svg>
        <span class="sidebar-brand-name">Bliss BD Admin</span>
      </div>

      <div class="sidebar-user">
        <div class="user-avatar">
          <%= currentUser.charAt(0).toUpperCase() %>
        </div>
        <div class="user-meta">
          <h5><%= currentUser %></h5>
          <span>Administrator</span>
        </div>
      </div>

      <nav class="sidebar-menu-wrapper">
        <ul class="sidebar-menu">
          <li class="sidebar-item active" data-panel="overview">
            <a class="sidebar-link">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="7" height="9"/>
                <rect x="14" y="3" width="7" height="5"/>
                <rect x="14" y="12" width="7" height="9"/>
                <rect x="3" y="16" width="7" height="5"/>
              </svg>
              <span>Overview</span>
            </a>
          </li>
          <li class="sidebar-item" data-panel="bookings">
            <a class="sidebar-link">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                <line x1="16" y1="2" x2="16" y2="6"/>
                <line x1="8" y1="2" x2="8" y2="6"/>
                <line x1="3" y1="10" x2="21" y2="10"/>
              </svg>
              <span>Appointments</span>
            </a>
          </li>
          <li class="sidebar-item" data-panel="inquiries">
            <a class="sidebar-link">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
              <span>Inquiries</span>
            </a>
          </li>
          <li class="sidebar-item" data-panel="settings">
            <a class="sidebar-link">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="3"/>
                <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
              </svg>
              <span>Manage Website</span>
            </a>
          </li>
          <li class="sidebar-item" data-panel="users">
            <a class="sidebar-link">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
              <span>User Accounts</span>
            </a>
          </li>
        </ul>
      </nav>

      <div class="sidebar-footer">
        <a href="/admin/logout" class="sidebar-logout">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
            <polyline points="16 17 21 12 16 7"/>
            <line x1="21" y1="12" x2="9" y2="12"/>
          </svg>
          <span>Log Out</span>
        </a>
      </div>
    </aside>

    <!-- Main Workspace -->
    <main class="admin-main">
      <header class="admin-header">
        <div class="admin-header-title">
          <h2 id="pageTitle">Overview Panel</h2>
        </div>
        <div class="admin-header-actions">
          <a href="/" target="_blank" class="live-site-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
              <polyline points="15 3 21 3 21 9"/>
              <line x1="10" y1="14" x2="21" y2="3"/>
            </svg>
            <span>View Live Site</span>
          </a>
        </div>
      </header>

      <div class="admin-content">
        
        <!-- Alerts Box -->
        <div id="dashboardAlert" class="alert alert-success hidden"></div>

        <!-- ==========================================
             PANEL 1: OVERVIEW
             ========================================== -->
        <div class="dashboard-panel active" id="panel-overview">
          <!-- Stats Widgets -->
          <div class="overview-grid">
            <div class="widget-card">
              <div class="widget-info">
                <h4>Total Bookings</h4>
                <p class="widget-value" id="stat-total-bookings"><%= bookings.length %></p>
              </div>
              <div class="widget-icon-box vax">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                  <line x1="16" y1="2" x2="16" y2="6"/>
                  <line x1="8" y1="2" x2="8" y2="6"/>
                  <line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
              </div>
            </div>
            
            <div class="widget-card">
              <div class="widget-info">
                <h4>Pending Bookings</h4>
                <p class="widget-value" id="stat-pending-bookings">
                  <%= bookings.filter(b => b.status === 'Pending').length %>
                </p>
              </div>
              <div class="widget-icon-box msg">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10"/>
                  <polyline points="12 6 12 12 16 14"/>
                </svg>
              </div>
            </div>

            <div class="widget-card">
              <div class="widget-info">
                <h4>Customer Messages</h4>
                <p class="widget-value" id="stat-total-messages"><%= contacts.length %></p>
              </div>
              <div class="widget-icon-box msg">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                  <polyline points="22,6 12,13 2,6"/>
                </svg>
              </div>
            </div>

            <div class="widget-card">
              <div class="widget-info">
                <h4>Admin Accounts</h4>
                <p class="widget-value" id="stat-total-admins"><%= users.length %></p>
              </div>
              <div class="widget-icon-box usr">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                  <circle cx="9" cy="7" r="4"/>
                </svg>
              </div>
            </div>
          </div>

          <div class="dashboard-content-grid">
            <!-- Recent Bookings Card -->
            <div class="panel-card">
              <div class="panel-card-header">
                <h3>Recent Appointments</h3>
                <button class="btn btn-secondary btn-sm" onclick="switchTab('bookings')">Manage All</button>
              </div>
              <div class="panel-card-body">
                <div class="table-responsive">
                  <table class="admin-table">
                    <thead>
                      <tr>
                        <th>Patient</th>
                        <th>Service</th>
                        <th>Date & Time</th>
                        <th>Status</th>
                        <th>Action</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% if(bookings.length === 0) { %>
                        <tr><td colspan="5" style="text-align: center; color: var(--color-text-muted);">No appointment records yet.</td></tr>
                      <% } else { %>
                        <% bookings.slice(0, 5).forEach(b => { %>
                          <tr id="booking-row-ov-<%= b.id %>">
                            <td>
                              <strong><%= b.patient_name %></strong><br>
                              <span style="font-size: 0.75rem; color: var(--color-text-muted);"><%= b.phone %></span>
                            </td>
                            <td><%= b.service %></td>
                            <td>
                              <%= b.appointment_date %><br>
                              <span style="font-size: 0.75rem; color: var(--color-text-muted);"><%= b.time_slot %></span>
                            </td>
                            <td>
                              <span class="status-badge <%= b.status.toLowerCase() %>"><%= b.status %></span>
                            </td>
                            <td>
                              <div class="actions-cell">
                                <% if(b.status === 'Pending') { %>
                                  <button class="action-btn btn-confirm" onclick="updateBookingStatus(<%= b.id %>, 'Confirmed')" title="Confirm Booking">✓</button>
                                  <button class="action-btn btn-cancel" onclick="updateBookingStatus(<%= b.id %>, 'Cancelled')" title="Cancel Booking">×</button>
                                <% } else if(b.status === 'Confirmed') { %>
                                  <button class="action-btn btn-complete" onclick="updateBookingStatus(<%= b.id %>, 'Completed')" title="Mark Completed">✓</button>
                                <% } else { %>
                                  <span style="color: var(--color-text-muted); font-size: 0.8rem;">None</span>
                                <% } %>
                              </div>
                            </td>
                          </tr>
                        <% }) %>
                      <% } %>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>

            <!-- Recent Inquiries Panel -->
            <div class="panel-card">
              <div class="panel-card-header">
                <h3>Latest Inquiries</h3>
                <button class="btn btn-secondary btn-sm" onclick="switchTab('inquiries')">Manage All</button>
              </div>
              <div class="panel-card-body">
                <div class="inquiry-list">
                  <% if(contacts.length === 0) { %>
                    <p style="text-align: center; color: var(--color-text-muted); margin: 20px 0;">No inquiries received yet.</p>
                  <% } else { %>
                    <% contacts.slice(0, 3).forEach(c => { %>
                      <div class="inquiry-item" style="padding: 12px; font-size: 0.85rem;" id="inquiry-card-ov-<%= c.id %>">
                        <div class="inquiry-header" style="margin-bottom: 6px;">
                          <strong><%= c.name %></strong>
                          <span class="status-badge <%= c.status.toLowerCase() %>" style="font-size: 0.65rem;"><%= c.status %></span>
                        </div>
                        <p style="margin: 4px 0; font-size: 0.8rem; color: var(--color-text-muted);"><%= c.phone %></p>
                        <p style="margin: 6px 0; color: #475569; font-style: italic;">"<%= c.message.length > 80 ? c.message.substring(0, 80) + '...' : c.message %>"</p>
                      </div>
                    <% }) %>
                  <% } %>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- ==========================================
             PANEL 2: BOOKINGS (APPOINTMENTS)
             ========================================== -->
        <div class="dashboard-panel" id="panel-bookings">
          <div class="panel-card">
            <div class="panel-card-header">
              <h3>Manage Patient Appointments</h3>
              <div class="filter-tabs">
                <button class="filter-btn active" onclick="filterBookings('All')">All</button>
                <button class="filter-btn" onclick="filterBookings('Pending')">Pending</button>
                <button class="filter-btn" onclick="filterBookings('Confirmed')">Confirmed</button>
                <button class="filter-btn" onclick="filterBookings('Completed')">Completed</button>
                <button class="filter-btn" onclick="filterBookings('Cancelled')">Cancelled</button>
              </div>
            </div>
            <div class="panel-card-body">
              <div class="table-responsive">
                <table class="admin-table" id="bookingsTable">
                  <thead>
                    <tr>
                      <th>Patient Details</th>
                      <th>Service Required</th>
                      <th>Date Requested</th>
                      <th>Time Slot</th>
                      <th>Status</th>
                      <th>Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if(bookings.length === 0) { %>
                      <tr class="no-records-row"><td colspan="6" style="text-align: center; color: var(--color-text-muted); padding: 30px;">No appointments recorded in system.</td></tr>
                    <% } else { %>
                      <% bookings.forEach(b => { %>
                        <tr id="booking-row-<%= b.id %>" class="booking-data-row" data-status="<%= b.status %>">
                          <td>
                            <strong><%= b.patient_name %></strong><br>
                            <span style="font-size: 0.8rem; color: var(--color-text-muted);">Phone: <%= b.phone %></span><br>
                            <span style="font-size: 0.75rem; color: var(--color-text-muted);">DOB: <%= b.dob || 'Not provided' %></span>
                          </td>
                          <td>
                            <span style="font-weight: 500;"><%= b.service %></span>
                          </td>
                          <td><%= b.appointment_date %></td>
                          <td><%= b.time_slot %></td>
                          <td>
                            <span class="status-badge <%= b.status.toLowerCase() %>" id="status-tag-<%= b.id %>"><%= b.status %></span>
                          </td>
                          <td>
                            <div class="actions-cell">
                              <button class="action-btn btn-confirm" onclick="updateBookingStatus(<%= b.id %>, 'Confirmed')" title="Confirm Appointment">✓</button>
                              <button class="action-btn btn-complete" onclick="updateBookingStatus(<%= b.id %>, 'Completed')" title="Mark Completed">✔</button>
                              <button class="action-btn btn-cancel" onclick="updateBookingStatus(<%= b.id %>, 'Cancelled')" title="Cancel Appointment">×</button>
                              <button class="action-btn btn-delete" onclick="deleteBooking(<%= b.id %>)" title="Delete Record">🗑</button>
                            </div>
                          </td>
                        </tr>
                      <% }) %>
                    <% } %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>

        <!-- ==========================================
             PANEL 3: INQUIRIES
             ========================================== -->
        <div class="dashboard-panel" id="panel-inquiries">
          <div class="panel-card">
            <div class="panel-card-header">
              <h3>Customer Messages & Inquiries</h3>
            </div>
            <div class="panel-card-body">
              <div class="inquiry-list" id="inquiriesContainer">
                <% if(contacts.length === 0) { %>
                  <p id="noInquiriesText" style="text-align: center; color: var(--color-text-muted); padding: 40px;">No messages received through contact forms yet.</p>
                <% } else { %>
                  <% contacts.forEach(c => { %>
                    <div class="inquiry-item" id="inquiry-card-<%= c.id %>">
                      <div class="inquiry-header">
                        <div class="inquiry-meta">
                          <h5><%= c.name %></h5>
                          <div class="contact-details">
                            <span><strong>Phone:</strong> <%= c.phone %></span>
                            <% if(c.email) { %>
                              <span><strong>Email:</strong> <%= c.email %></span>
                            <% } %>
                          </div>
                        </div>
                        <div style="text-align: right;">
                          <span class="status-badge <%= c.status.toLowerCase() %>" id="inquiry-status-<%= c.id %>"><%= c.status %></span><br>
                          <span class="inquiry-date" style="display:inline-block; margin-top:5px;"><%= new Date(c.created_at).toLocaleDateString() %></span>
                        </div>
                      </div>
                      <div class="inquiry-body">
                        <%= c.message %>
                      </div>
                      <div class="inquiry-footer">
                        <% if(c.status === 'Pending') { %>
                          <button class="btn btn-secondary btn-sm" id="btn-read-<%= c.id %>" onclick="updateInquiryStatus(<%= c.id %>, 'Replied')">Mark Replied</button>
                        <% } %>
                        <button class="btn btn-danger btn-sm" onclick="deleteInquiry(<%= c.id %>)" style="background-color: var(--color-status-cancelled); border:none;">Delete Message</button>
                      </div>
                    </div>
                  <% }) %>
                <% } %>
              </div>
            </div>
          </div>
        </div>

        <!-- ==========================================
             PANEL 4: SETTINGS (MANAGE WEBSITE DATA)
             ========================================== -->
        <div class="dashboard-panel" id="panel-settings">
          <form id="websiteSettingsForm" class="admin-form">
            
            <!-- Hero Settings -->
            <div class="panel-card">
              <div class="panel-card-header">
                <h3>Hero Banner Configuration</h3>
              </div>
              <div class="panel-card-body">
                <div class="form-group">
                  <label for="hero_title">Hero Title Text (supports HTML like &lt;br&gt;)</label>
                  <input type="text" id="hero_title" name="hero_title" value="<%= settings.hero_title %>" class="form-control" required>
                </div>
                <div class="form-group">
                  <label for="hero_description">Hero Description Text</label>
                  <textarea id="hero_description" name="hero_description" rows="3" class="form-control" required><%= settings.hero_description %></textarea>
                </div>
              </div>
            </div>

            <!-- About Us Settings -->
            <div class="panel-card">
              <div class="panel-card-header">
                <h3>About Us Page Section</h3>
              </div>
              <div class="panel-card-body">
                <div class="form-group">
                  <label for="about_subtitle">Section Subtitle</label>
                  <input type="text" id="about_subtitle" name="about_subtitle" value="<%= settings.about_subtitle %>" class="form-control" required>
                </div>
                <div class="form-group">
                  <label for="about_paragraph_1">About Description Paragraph 1</label>
                  <textarea id="about_paragraph_1" name="about_paragraph_1" rows="3" class="form-control" required><%= settings.about_paragraph_1 %></textarea>
                </div>
                <div class="form-group">
                  <label for="about_paragraph_2">About Description Paragraph 2</label>
                  <textarea id="about_paragraph_2" name="about_paragraph_2" rows="3" class="form-control" required><%= settings.about_paragraph_2 %></textarea>
                </div>
                
                <div class="form-grid">
                  <div class="form-group">
                    <label for="stat_children">Children Immunized Stat</label>
                    <input type="text" id="stat_children" name="stat_children" value="<%= settings.stat_children %>" class="form-control" required>
                  </div>
                  <div class="form-group">
                    <label for="stat_staff">Staff Strength Stat</label>
                    <input type="text" id="stat_staff" name="stat_staff" value="<%= settings.stat_staff %>" class="form-control" required>
                  </div>
                  <div class="form-group">
                    <label for="stat_satisfaction">Satisfaction Rate Stat</label>
                    <input type="text" id="stat_satisfaction" name="stat_satisfaction" value="<%= settings.stat_satisfaction %>" class="form-control" required>
                  </div>
                </div>

                <div class="form-group">
                  <label for="feature_epi_desc">Govt Authorized Feature Summary</label>
                  <input type="text" id="feature_epi_desc" name="feature_epi_desc" value="<%= settings.feature_epi_desc %>" class="form-control" required>
                </div>
                <div class="form-group">
                  <label for="feature_confidentiality_desc">100% Confidentiality Feature Summary</label>
                  <input type="text" id="feature_confidentiality_desc" name="feature_confidentiality_desc" value="<%= settings.feature_confidentiality_desc %>" class="form-control" required>
                </div>
                <div class="form-group">
                  <label for="feature_affordability_desc">Affordable Plans Feature Summary</label>
                  <input type="text" id="feature_affordability_desc" name="feature_affordability_desc" value="<%= settings.feature_affordability_desc %>" class="form-control" required>
                </div>
              </div>
            </div>

            <!-- Service Overviews -->
            <div class="panel-card">
              <div class="panel-card-header">
                <h3>Services Box Overviews</h3>
              </div>
              <div class="panel-card-body">
                <div class="form-grid">
                  <div class="form-group">
                    <label for="service_vax_desc">EPI Vaccination Service Overview Text</label>
                    <textarea id="service_vax_desc" name="service_vax_desc" rows="2" class="form-control" required><%= settings.service_vax_desc %></textarea>
                  </div>
                  <div class="form-group">
                    <label for="service_fp_desc">Family Planning Service Overview Text</label>
                    <textarea id="service_fp_desc" name="service_fp_desc" rows="2" class="form-control" required><%= settings.service_fp_desc %></textarea>
                  </div>
                  <div class="form-group">
                    <label for="service_anc_desc">Antenatal Care Service Overview Text</label>
                    <textarea id="service_anc_desc" name="service_anc_desc" rows="2" class="form-control" required><%= settings.service_anc_desc %></textarea>
                  </div>
                  <div class="form-group">
                    <label for="service_autism_desc">Autism Support Service Overview Text</label>
                    <textarea id="service_autism_desc" name="service_autism_desc" rows="2" class="form-control" required><%= settings.service_autism_desc %></textarea>
                  </div>
                </div>
              </div>
            </div>

            <!-- Service Specific Modals details (Advanced) -->
            <div class="panel-card">
              <div class="panel-card-header">
                <h3>Service Modals Detail Content</h3>
              </div>
              <div class="panel-card-body">
                
                <!-- Vaccination Modal Content -->
                <h4 class="form-section-title">EPI Vaccination Modal Details</h4>
                <div class="form-group">
                  <label for="service_vax_title">Modal Title</label>
                  <input type="text" id="service_vax_title" name="service_vax_title" value="<%= settings.service_vax_title %>" class="form-control" required>
                </div>
                <div class="form-group">
                  <label for="service_vax_details">Modal Detailed Paragraph</label>
                  <textarea id="service_vax_details" name="service_vax_details" rows="3" class="form-control" required><%= settings.service_vax_details %></textarea>
                </div>
                <div class="form-grid">
                  <div class="form-group">
                    <label for="service_vax_hl_1">Highlight 1</label>
                    <input type="text" id="service_vax_hl_1" name="service_vax_hl_1" value="<%= settings.service_vax_hl_1 %>" class="form-control" required>
                  </div>
                  <div class="form-group">
                    <label for="service_vax_hl_2">Highlight 2</label>
                    <input type="text" id="service_vax_hl_2" name="service_vax_hl_2" value="<%= settings.service_vax_hl_2 %>" class="form-control" required>
                  </div>
                  <div class="form-group">
                    <label for="service_vax_hl_3">Highlight 3</label>
                    <input type="text" id="service_vax_hl_3" name="service_vax_hl_3" value="<%= settings.service_vax_hl_3 %>" class="form-control" required>
                  </div>
                  <div class="form-group">
                    <label for="service_vax_hl_4">Highlight 4</label>
                    <input type="text" id="service_vax_hl_4" name="service_vax_hl_4" value="<%= settings.service_vax_hl_4 %>" class="form-control" required>
                  </div>
                </div>

                <!-- Family Planning Modal Content -->
                <h4 class="form-section-title">Family Planning Modal Details</h4>
                <div class="form-group">
                  <label for="service_fp_title">Modal Title</label>
                  <input type="text" id="service_fp_title" name="service_fp_title" value="<%= settings.service_fp_title %>" class="form-control" required>
                </div>
                <div class="form-group">
                  <label for="service_fp_details">Modal Detailed Paragraph</label>
                  <textarea id="service_fp_details" name="service_fp_details" rows="3" class="form-control" required><%= settings.service_fp_details %></textarea>
                </div>
                <div class="form-grid">
                  <div class="form-group">
                    <label for="service_fp_hl_1">Highlight 1</label>
                    <input type="text" id="service_fp_hl_1" name="service_fp_hl_1" value="<%= settings.service_fp_hl_1 %>" class="form-control" required>
                  </div>
                  <div class="form-group">
                    <label for="service_fp_hl_2">Highlight 2</label>
                    <input type="text" id="service_fp_hl_2" name="service_fp_hl_2" value="<%= settings.service_fp_hl_2 %>" class="form-control" required>
                  </div>
                  <div class="form-group">
                    <label for="service_fp_hl_3">Highlight 3</label>
                    <input type="text" id="service_fp_hl_3" name="service_fp_hl_3" value="<%= settings.service_fp_hl_3 %>" class="form-control" required>
                  </div>
                  <div class="form-group">
                    <label for="service_fp_hl_4">Highlight 4</label>
                    <input type="text" id="service_fp_hl_4" name="service_fp_hl_4" value="<%= settings.service_fp_hl_4 %>" class="form-control" required>
                  </div>
                </div>

                <!-- Antenatal Modal Content -->
                <h4 class="form-section-title">Antenatal Care Modal Details</h4>
                <div class="form-group">
                  <label for="service_anc_title">Modal Title</label>
                  <input type="text" id="service_anc_title" name="service_anc_title" value="<%= settings.service_anc_title %>" class="form-control" required>
                </div>
                <div class="form-group">
                  <label for="service_anc_details">Modal Detailed Paragraph</label>
                  <textarea id="service_anc_details" name="service_anc_details" rows="3" class="form-control" required><%= settings.service_anc_details %></textarea>
                </div>
                <div class="form-grid">
                  <div class="form-group">
                    <label for="service_anc_hl_1">Highlight 1</label>
                    <input type="text" id="service_anc_hl_1" name="service_anc_hl_1" value="<%= settings.service_anc_hl_1 %>" class="form-control" required>
                  </div>
                  <div class="form-group">
                    <label for="service_anc_hl_2">Highlight 2</label>
                    <input type="text" id="service_anc_hl_2" name="service_anc_hl_2" value="<%= settings.service_anc_hl_2 %>" class="form-control" required>
                  </div>
                  <div class="form-group">
                    <label for="service_anc_hl_3">Highlight 3</label>
                    <input type="text" id="service_anc_hl_3" name="service_anc_hl_3" value="<%= settings.service_anc_hl_3 %>" class="form-control" required>
                  </div>
                  <div class="form-group">
                    <label for="service_anc_hl_4">Highlight 4</label>
                    <input type="text" id="service_anc_hl_4" name="service_anc_hl_4" value="<%= settings.service_anc_hl_4 %>" class="form-control" required>
                  </div>
                </div>

                <!-- Autism Modal Content -->
                <h4 class="form-section-title">Autism Support Modal Details</h4>
                <div class="form-group">
                  <label for="service_autism_title">Modal Title</label>
                  <input type="text" id="service_autism_title" name="service_autism_title" value="<%= settings.service_autism_title %>" class="form-control" required>
                </div>
                <div class="form-group">
                  <label for="service_autism_details">Modal Detailed Paragraph</label>
                  <textarea id="service_autism_details" name="service_autism_details" rows="3" class="form-control" required><%= settings.service_autism_details %></textarea>
                </div>
                <div class="form-grid">
                  <div class="form-group">
                    <label for="service_autism_hl_1">Highlight 1</label>
                    <input type="text" id="service_autism_hl_1" name="service_autism_hl_1" value="<%= settings.service_autism_hl_1 %>" class="form-control" required>
                  </div>
                  <div class="form-group">
                    <label for="service_autism_hl_2">Highlight 2</label>
                    <input type="text" id="service_autism_hl_2" name="service_autism_hl_2" value="<%= settings.service_autism_hl_2 %>" class="form-control" required>
                  </div>
                  <div class="form-group">
                    <label for="service_autism_hl_3">Highlight 3</label>
                    <input type="text" id="service_autism_hl_3" name="service_autism_hl_3" value="<%= settings.service_autism_hl_3 %>" class="form-control" required>
                  </div>
                  <div class="form-group">
                    <label for="service_autism_hl_4">Highlight 4</label>
                    <input type="text" id="service_autism_hl_4" name="service_autism_hl_4" value="<%= settings.service_autism_hl_4 %>" class="form-control" required>
                  </div>
                </div>

              </div>
            </div>

            <!-- Contact Information Settings -->
            <div class="panel-card">
              <div class="panel-card-header">
                <h3>Contact & Center Settings</h3>
              </div>
              <div class="panel-card-body">
                <div class="form-grid">
                  <div class="form-group">
                    <label for="contact_phone">Primary Phone Number</label>
                    <input type="text" id="contact_phone" name="contact_phone" value="<%= settings.contact_phone %>" class="form-control" required>
                  </div>
                  <div class="form-group">
                    <label for="contact_phone_alt">Alternate Phone Number</label>
                    <input type="text" id="contact_phone_alt" name="contact_phone_alt" value="<%= settings.contact_phone_alt %>" class="form-control" required>
                  </div>
                  <div class="form-group">
                    <label for="contact_email">Primary Email</label>
                    <input type="email" id="contact_email" name="contact_email" value="<%= settings.contact_email %>" class="form-control" required>
                  </div>
                  <div class="form-group">
                    <label for="contact_email_alt">Support Email</label>
                    <input type="email" id="contact_email_alt" name="contact_email_alt" value="<%= settings.contact_email_alt %>" class="form-control" required>
                  </div>
                </div>
                
                <div class="form-group">
                  <label for="contact_address">Physical Address</label>
                  <input type="text" id="contact_address" name="contact_address" value="<%= settings.contact_address %>" class="form-control" required>
                </div>

                <div class="form-grid">
                  <div class="form-group">
                    <label for="opening_hours_weekdays">Opening Hours (Weekdays)</label>
                    <input type="text" id="opening_hours_weekdays" name="opening_hours_weekdays" value="<%= settings.opening_hours_weekdays %>" class="form-control" required>
                  </div>
                  <div class="form-group">
                    <label for="opening_hours_weekend">Opening Hours (Weekend)</label>
                    <input type="text" id="opening_hours_weekend" name="opening_hours_weekend" value="<%= settings.opening_hours_weekend %>" class="form-control" required>
                  </div>
                </div>
              </div>
            </div>

            <!-- Form Action Submit -->
            <div class="admin-form-actions">
              <button type="submit" class="btn btn-primary" id="saveSettingsBtn">Save All Settings</button>
            </div>

          </form>
        </div>

        <!-- ==========================================
             PANEL 5: USERS (ADMIN ACCOUNTS)
             ========================================== -->
        <div class="dashboard-panel" id="panel-users">
          <div class="dashboard-content-grid">
            
            <!-- List of Current Admin Users -->
            <div class="panel-card">
              <div class="panel-card-header">
                <h3>Admin System Accounts</h3>
              </div>
              <div class="panel-card-body">
                <div class="user-card-list" id="usersContainer">
                  <% users.forEach(u => { %>
                    <div class="user-card" id="user-card-<%= u.id %>">
                      <div class="user-card-info">
                        <h5><%= u.username %></h5>
                        <span>Created: <%= new Date(u.created_at).toLocaleDateString() %></span>
                      </div>
                      <div class="actions-cell">
                        <button class="action-btn" onclick="openChangePasswordModal(<%= u.id %>, '<%= u.username %>')" title="Change Password">🔑</button>
                        <% if(u.id !== currentUserId) { %>
                          <button class="action-btn btn-delete" onclick="deleteUser(<%= u.id %>)" title="Delete Account">🗑</button>
                        <% } %>
                      </div>
                    </div>
                  <% }) %>
                </div>
              </div>
            </div>

            <!-- Create New Admin Account -->
            <div class="panel-card">
              <div class="panel-card-header">
                <h3>Add New Administrator</h3>
              </div>
              <div class="panel-card-body">
                <form id="createAdminUserForm" class="admin-form">
                  <div id="createUserError" class="alert alert-danger hidden"></div>
                  <div class="form-group">
                    <label for="newUsername">Username *</label>
                    <input type="text" id="newUsername" name="username" required class="form-control" placeholder="e.g. nurse_rahima">
                  </div>
                  <div class="form-group">
                    <label for="newPassword">Password * (Min 6 chars)</label>
                    <input type="password" id="newPassword" name="password" required class="form-control" placeholder="••••••••" minlength="6">
                  </div>
                  <button type="submit" class="btn btn-primary btn-block" style="margin-top:15px;">Create Account</button>
                </form>
              </div>
            </div>

          </div>
        </div>

      </div>
    </main>
  </div>

  <!-- PASSWORD CHANGE MODAL -->
  <div class="modal-backdrop hidden" id="pwdModal">
    <div class="modal-card">
      <h3 style="font-family: var(--font-heading); margin-top:0; margin-bottom:10px;">Change Account Password</h3>
      <p style="font-size:0.85rem; color:var(--color-text-muted); margin-bottom:20px;">
        Setting new password for admin user: <strong id="pwdModalUser"></strong>
      </p>
      
      <form id="changePasswordForm" class="admin-form">
        <input type="hidden" id="pwdModalUserId">
        <div id="pwdModalError" class="alert alert-danger hidden"></div>
        
        <div class="form-group">
          <label for="newPasswordVal">New Password * (Min 6 chars)</label>
          <input type="password" id="newPasswordVal" required class="form-control" placeholder="••••••••" minlength="6">
        </div>
        
        <div class="admin-form-actions" style="margin-top: 20px; border:none; padding:0;">
          <button type="button" class="btn btn-secondary" onclick="closeChangePasswordModal()">Cancel</button>
          <button type="submit" class="btn btn-primary">Update Password</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Dashboard Script dependencies -->
  <script src="/admin.js"></script>

</body>
</html>
