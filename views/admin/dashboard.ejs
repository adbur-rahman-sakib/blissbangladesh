<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="Cache-Control" content="no-store, no-cache, must-revalidate">
  <title>Admin Dashboard | Bliss Bangladesh</title>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{
      --sidebar:#0F172A;--sidebar-border:rgba(255,255,255,.06);
      --primary:#0040A5;--primary-light:#EEF4FF;--primary-dark:#002d80;
      --success:#16A34A;--danger:#DC2626;--warning:#D97706;--info:#0891B2;
      --bg:#F1F5F9;--card:#FFFFFF;--border:#E2E8F0;
      --text:#1E293B;--muted:#64748B;--subtle:#94A3B8;
      --font-h:'Outfit',sans-serif;--font-b:'Inter',sans-serif;
      --r:10px;--sh:0 1px 3px rgba(0,0,0,.08),0 1px 2px rgba(0,0,0,.06);
    }
    body{font-family:var(--font-b);background:var(--bg);color:var(--text);display:flex;height:100vh;overflow:hidden}

    /* ─── Sidebar ─── */
    .sb{width:240px;background:var(--sidebar);display:flex;flex-direction:column;flex-shrink:0;overflow-y:auto}
    .sb-brand{padding:20px 18px 14px;display:flex;align-items:center;gap:10px;border-bottom:1px solid var(--sidebar-border)}
    .sb-logo{width:36px;height:36px;background:var(--primary);border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
    .sb-name{font-family:var(--font-h);font-weight:800;font-size:.95rem;color:#fff;line-height:1.2}
    .sb-name small{display:block;font-size:.65rem;font-weight:400;color:var(--subtle);font-family:var(--font-b)}
    .sb-user{padding:14px 18px;display:flex;align-items:center;gap:10px;border-bottom:1px solid var(--sidebar-border)}
    .avatar{width:34px;height:34px;border-radius:50%;background:var(--primary);color:#fff;font-family:var(--font-h);font-weight:700;font-size:.9rem;display:flex;align-items:center;justify-content:center;flex-shrink:0}
    .sb-user-info{min-width:0}
    .sb-user-name{font-size:.84rem;font-weight:600;color:#fff;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .role-pill{display:inline-block;padding:1px 8px;border-radius:20px;font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px}
    .rp-admin{background:rgba(239,68,68,.2);color:#FCA5A5}
    .rp-manager{background:rgba(0,64,165,.25);color:#93C5FD}
    .rp-editor{background:rgba(22,163,74,.2);color:#86EFAC}
    .sb-nav{flex:1;padding:10px 0}
    .nav-link{display:flex;align-items:center;gap:10px;padding:10px 18px;color:var(--subtle);font-size:.84rem;font-weight:500;cursor:pointer;border-left:3px solid transparent;transition:all .15s;white-space:nowrap}
    .nav-link:hover{background:rgba(255,255,255,.05);color:#fff}
    .nav-link.active{background:rgba(0,64,165,.2);color:#fff;border-left-color:var(--primary)}
    .nav-link svg{flex-shrink:0;opacity:.7}
    .nav-link.active svg{opacity:1}
    .nav-section{padding:14px 18px 6px;font-size:.65rem;font-weight:700;color:var(--subtle);text-transform:uppercase;letter-spacing:.8px}
    .sb-foot{padding:14px 18px;border-top:1px solid var(--sidebar-border)}
    .sb-logout{display:flex;align-items:center;gap:8px;color:var(--subtle);font-size:.82rem;text-decoration:none;transition:color .15s}
    .sb-logout:hover{color:#fff}

    /* ─── Main ─── */
    .main{flex:1;display:flex;flex-direction:column;min-width:0;overflow:hidden}
    .topbar{background:var(--card);border-bottom:1px solid var(--border);padding:0 24px;height:56px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0}
    .topbar-title{font-family:var(--font-h);font-size:1rem;font-weight:700;color:var(--text)}
    .topbar-actions{display:flex;align-items:center;gap:10px}
    .view-site{display:inline-flex;align-items:center;gap:6px;padding:6px 14px;border-radius:8px;background:var(--primary-light);color:var(--primary);font-size:.8rem;font-weight:600;text-decoration:none}
    .content{flex:1;overflow-y:auto;padding:22px 24px}

    /* ─── Toast ─── */
    #toast{position:fixed;top:20px;right:20px;z-index:9999;display:flex;flex-direction:column;gap:8px;pointer-events:none}
    .toast-item{padding:12px 18px;border-radius:10px;font-size:.84rem;font-weight:600;max-width:340px;box-shadow:0 4px 16px rgba(0,0,0,.15);animation:slideIn .2s ease;pointer-events:auto}
    .toast-success{background:#D1FAE5;color:#065F46;border:1px solid #6EE7B7}
    .toast-danger{background:#FEE2E2;color:#991B1B;border:1px solid #FCA5A5}
    .toast-warning{background:#FEF3C7;color:#92400E;border:1px solid #FDE68A}
    @keyframes slideIn{from{transform:translateX(20px);opacity:0}to{transform:translateX(0);opacity:1}}

    /* ─── Panels ─── */
    .panel{display:none}.panel.active{display:block}

    /* ─── Stats grid ─── */
    .stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:16px;margin-bottom:22px}
    .stat{background:var(--card);border-radius:var(--r);padding:20px;box-shadow:var(--sh);display:flex;align-items:center;gap:14px}
    .stat-icon{width:44px;height:44px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
    .si-blue{background:#DBEAFE;color:var(--primary)}
    .si-green{background:#D1FAE5;color:var(--success)}
    .si-yellow{background:#FEF3C7;color:var(--warning)}
    .si-red{background:#FEE2E2;color:var(--danger)}
    .si-purple{background:#EDE9FE;color:#7C3AED}
    .stat-info p{font-size:.72rem;color:var(--muted);font-weight:500;text-transform:uppercase;letter-spacing:.4px;margin-bottom:3px}
    .stat-val{font-family:var(--font-h);font-size:1.8rem;font-weight:800;color:var(--text);line-height:1}

    /* ─── Card ─── */
    .card{background:var(--card);border-radius:var(--r);box-shadow:var(--sh);margin-bottom:18px;overflow:hidden}
    .card-head{padding:14px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap}
    .card-head h3{font-family:var(--font-h);font-size:.95rem;font-weight:700}
    .card-body{padding:18px}

    /* ─── Grid layouts ─── */
    .g2{display:grid;grid-template-columns:1fr 360px;gap:18px}
    .g2-eq{display:grid;grid-template-columns:1fr 1fr;gap:18px}
    @media(max-width:900px){.g2,.g2-eq{grid-template-columns:1fr}}

    /* ─── Table ─── */
    .tbl-wrap{overflow-x:auto}
    table{width:100%;border-collapse:collapse;font-size:.83rem}
    thead{background:#F8FAFC}
    th{padding:9px 14px;text-align:left;font-weight:600;color:var(--muted);font-size:.72rem;text-transform:uppercase;letter-spacing:.4px;border-bottom:1px solid var(--border);white-space:nowrap}
    td{padding:11px 14px;border-bottom:1px solid #F8FAFC;vertical-align:middle}
    tr:last-child td{border-bottom:none}
    tr:hover td{background:#FAFAFA}

    /* ─── Badges ─── */
    .badge{display:inline-block;padding:2px 10px;border-radius:20px;font-size:.7rem;font-weight:700;text-transform:capitalize;white-space:nowrap}
    .b-pending{background:#FEF3C7;color:#92400E}
    .b-confirmed{background:#DBEAFE;color:#1E40AF}
    .b-completed{background:#D1FAE5;color:#065F46}
    .b-cancelled{background:#FEE2E2;color:#991B1B}
    .b-replied{background:#EDE9FE;color:#6D28D9}
    .b-published{background:#D1FAE5;color:#065F46}
    .b-draft{background:#F1F5F9;color:var(--muted)}
    .b-admin{background:rgba(239,68,68,.15);color:#B91C1C}
    .b-manager{background:rgba(0,64,165,.12);color:var(--primary)}
    .b-editor{background:rgba(22,163,74,.12);color:#15803D}

    /* ─── Buttons ─── */
    .btn{display:inline-flex;align-items:center;gap:5px;padding:7px 14px;border-radius:7px;font-size:.82rem;font-weight:600;cursor:pointer;border:none;transition:all .15s;font-family:var(--font-b);white-space:nowrap}
    .btn-primary{background:var(--primary);color:#fff}.btn-primary:hover{background:var(--primary-dark)}
    .btn-success{background:var(--success);color:#fff}.btn-success:hover{background:#15803D}
    .btn-danger{background:var(--danger);color:#fff}.btn-danger:hover{background:#B91C1C}
    .btn-warning{background:var(--warning);color:#fff}.btn-warning:hover{background:#B45309}
    .btn-ghost{background:#F1F5F9;color:var(--text)}.btn-ghost:hover{background:#E2E8F0}
    .btn-sm{padding:5px 10px;font-size:.76rem}
    .btn:disabled{opacity:.5;cursor:not-allowed}
    .ib{width:30px;height:30px;border-radius:7px;border:none;cursor:pointer;display:inline-flex;align-items:center;justify-content:center;font-size:.85rem;transition:all .15s}
    .ib-edit{background:#EEF4FF;color:var(--primary)}.ib-edit:hover{background:#DBEAFE}
    .ib-del{background:#FEE2E2;color:var(--danger)}.ib-del:hover{background:#FECACA}
    .ib-key{background:#FEF3C7;color:var(--warning)}.ib-key:hover{background:#FDE68A}
    .ib-eye{background:#F0FDF4;color:var(--success)}.ib-eye:hover{background:#DCFCE7}
    .act-row{display:flex;gap:5px;align-items:center}

    /* ─── Forms ─── */
    .fg{display:flex;flex-direction:column;gap:5px;margin-bottom:14px}
    .fg label{font-size:.78rem;font-weight:600;color:var(--text)}
    .fc{width:100%;padding:8px 11px;border:1.5px solid var(--border);border-radius:7px;font-size:.84rem;font-family:var(--font-b);color:var(--text);background:#fff;transition:border-color .15s}
    .fc:focus{outline:none;border-color:var(--primary)}
    .fc[type=file]{padding:6px}
    select.fc{cursor:pointer}
    textarea.fc{resize:vertical}
    .fgrid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
    .fgrid.g3{grid-template-columns:1fr 1fr 1fr}
    .hl-list{display:flex;flex-direction:column;gap:7px;margin-top:4px}
    .hl-row{display:flex;gap:7px;align-items:center}
    .hl-row .fc{flex:1;margin-bottom:0}
    .btn-hl-rm{flex-shrink:0;background:none;border:1.5px solid #FECACA;color:#DC2626;border-radius:6px;padding:5px 9px;cursor:pointer;font-size:.82rem;line-height:1;transition:background .15s}
    .btn-hl-rm:hover{background:#FEE2E2}
    .btn-hl-add{margin-top:8px;font-size:.78rem;padding:5px 12px;color:var(--color-primary);border:1.5px dashed var(--color-primary);background:none;border-radius:6px;cursor:pointer;font-family:var(--font-b);transition:background .15s}
    .btn-hl-add:hover{background:#EFF6FF}
    .span2{grid-column:1/-1}
    .f-actions{display:flex;gap:10px;margin-top:16px;justify-content:flex-end}
    .inline-cb{display:flex;align-items:center;gap:7px;cursor:pointer;font-size:.84rem;font-weight:500}

    /* ─── Alert inline ─── */
    .alert{padding:9px 13px;border-radius:7px;font-size:.81rem;font-weight:600;margin-bottom:12px;display:none}
    .alert.show{display:block}
    .alert-danger{background:#FEE2E2;color:#991B1B}
    .alert-success{background:#D1FAE5;color:#065F46}

    /* ─── Modal ─── */
    .modal-overlay{position:fixed;inset:0;background:rgba(15,23,42,.55);backdrop-filter:blur(3px);z-index:1000;display:none;align-items:center;justify-content:center;padding:20px}
    .modal-overlay.open{display:flex}
    .modal{background:var(--card);border-radius:14px;width:100%;max-width:520px;max-height:90vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,.25)}
    .modal-head{padding:18px 22px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
    .modal-head h3{font-family:var(--font-h);font-size:1rem;font-weight:700}
    .modal-close{width:28px;height:28px;border-radius:6px;border:none;background:#F1F5F9;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:1rem;color:var(--muted)}
    .modal-close:hover{background:#E2E8F0}
    .modal-body{padding:20px 22px}
    .modal-foot{padding:14px 22px;border-top:1px solid var(--border);display:flex;gap:10px;justify-content:flex-end}

    /* ─── Sections list ─── */
    .sec-item{display:flex;align-items:center;gap:12px;padding:12px 0;border-bottom:1px solid var(--border)}
    .sec-item:last-child{border-bottom:none}
    .sec-thumb{width:60px;height:44px;border-radius:6px;background:#F1F5F9;flex-shrink:0;overflow:hidden;display:flex;align-items:center;justify-content:center}
    .sec-thumb img{width:100%;height:100%;object-fit:cover}
    .sec-info{flex:1;min-width:0}
    .sec-info h5{font-size:.86rem;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .sec-info p{font-size:.75rem;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-top:2px}
    .sec-acts{display:flex;gap:5px;flex-shrink:0}

    /* ─── Inquiry cards ─── */
    .inq-card{border:1px solid var(--border);border-radius:var(--r);padding:14px;margin-bottom:10px}
    .inq-head{display:flex;justify-content:space-between;align-items:flex-start;gap:10px;margin-bottom:8px}
    .inq-meta h5{font-size:.88rem;font-weight:700}
    .inq-meta p{font-size:.75rem;color:var(--muted);margin-top:2px}
    .inq-body{font-size:.83rem;line-height:1.65;margin-bottom:10px;color:var(--text)}
    .inq-foot{display:flex;gap:7px}

    /* ─── Audit log ─── */
    .al-row{display:flex;align-items:flex-start;gap:12px;padding:10px 0;border-bottom:1px solid #F8FAFC}
    .al-row:last-child{border-bottom:none}
    .al-icon{width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.8rem;flex-shrink:0;margin-top:2px}
    .al-create{background:#D1FAE5;color:#065F46}
    .al-update{background:#DBEAFE;color:#1D4ED8}
    .al-delete{background:#FEE2E2;color:#991B1B}
    .al-login{background:#EDE9FE;color:#6D28D9}
    .al-other{background:#F1F5F9;color:var(--muted)}
    .btn-pdf-view{background:none;border:none;padding:0;font-size:.76rem;color:var(--primary);font-weight:600;cursor:pointer;text-decoration:underline;text-underline-offset:2px}
    .al-info p{font-size:.82rem;color:var(--text);line-height:1.4}
    .al-info small{font-size:.72rem;color:var(--muted)}

    /* ─── Image previews ─── */
    .img-prev{width:100%;height:90px;object-fit:cover;border-radius:7px;display:block;margin-top:6px}
    .img-ph{background:#F1F5F9;border:2px dashed var(--border);border-radius:7px;height:72px;display:flex;align-items:center;justify-content:center;color:var(--muted);font-size:.76rem;margin-top:6px}
    .img-upload-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:14px}
    .img-item label{font-size:.78rem;font-weight:600;display:block;margin-bottom:4px}

    /* ─── Chart placeholders ─── */
    .chart-ph{background:linear-gradient(135deg,var(--primary-light),#fff);border:1px dashed var(--primary);border-radius:var(--r);height:160px;display:flex;flex-direction:column;align-items:center;justify-content:center;color:var(--primary);font-size:.82rem;font-weight:600;gap:6px;opacity:.7}

    /* ─── Event category chips ─── */
    .chip{display:inline-block;padding:2px 9px;border-radius:20px;font-size:.7rem;font-weight:600}
    .chip-vax{background:#DBEAFE;color:#1D4ED8}
    .chip-health{background:#D1FAE5;color:#065F46}
    .chip-sem{background:#FEF3C7;color:#92400E}
    .chip-work{background:#EDE9FE;color:#6D28D9}
    .chip-com{background:#FFE4E6;color:#9F1239}
    .chip-gen{background:#F1F5F9;color:var(--muted)}

    /* Filter tabs */
    .filter-row{display:flex;gap:6px;flex-wrap:wrap}
    .fb{padding:4px 13px;border-radius:20px;border:1.5px solid var(--border);background:#fff;color:var(--muted);font-size:.76rem;font-weight:600;cursor:pointer;transition:all .15s}
    .fb.active,.fb:hover{border-color:var(--primary);background:var(--primary);color:#fff}

    /* Overview recent items */
    .rec-item{display:flex;align-items:center;justify-content:space-between;padding:9px 0;border-bottom:1px solid #F8FAFC;font-size:.83rem}
    .rec-item:last-child{border-bottom:none}
    .rec-name{font-weight:600}
    .rec-sub{font-size:.74rem;color:var(--muted)}
  </style>
</head>
<body>

<!-- ══════════════════════ SIDEBAR ══════════════════════ -->
<aside class="sb">
  <div class="sb-brand">
    <div class="sb-logo">
      <svg width="20" height="20" viewBox="0 0 48 48" fill="none">
        <path d="M24 16C24 16 20 12 18 14C16 16 17 20 20 23L24 26L28 23C31 20 32 16 30 14C28 12 24 16 24 16Z" fill="#fff"/>
        <path d="M12 28C14 33 20 36 24 36C28 36 34 33 36 28C33 30 28 28 24 28C20 28 15 30 12 28Z" fill="rgba(255,255,255,.75)"/>
      </svg>
    </div>
    <div class="sb-name">Bliss Bangladesh<small>Admin Panel</small></div>
  </div>

  <div class="sb-user">
    <div class="avatar"><%= currentUser.charAt(0).toUpperCase() %></div>
    <div class="sb-user-info">
      <div class="sb-user-name"><%= currentUser %></div>
      <span class="role-pill rp-<%= currentUserRole %>"><%= currentUserRole %></span>
    </div>
  </div>

  <nav class="sb-nav">
    <div class="nav-link active" data-panel="overview">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="9"/><rect x="14" y="3" width="7" height="5"/><rect x="14" y="12" width="7" height="9"/><rect x="3" y="16" width="7" height="5"/></svg>
      Overview
    </div>

    <div class="nav-section">Operations</div>
    <div class="nav-link" data-panel="bookings">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      Appointments <span id="nb-pending" style="margin-left:auto;background:#EF4444;color:#fff;border-radius:20px;font-size:.65rem;padding:1px 7px;font-weight:700"><%= bookings.filter(function(b){return b.status==='Pending'}).length %></span>
    </div>
    <div class="nav-link" data-panel="contacts">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
      Inquiries
    </div>

    <div class="nav-section">Content</div>
    <div class="nav-link" data-panel="events">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01"/></svg>
      Events
    </div>
    <div class="nav-link" data-panel="vaccines">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="2" x2="22" y2="6"/><line x1="17" y1="3" x2="9" y2="11"/><path d="M12 8l-6 6H3v-3l6-6"/></svg>
      Vaccine Schedule
    </div>
    <div class="nav-link" data-panel="sections">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
      Page Sections
    </div>
    <div class="nav-link" data-panel="resources">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
      Resources
    </div>
    <div class="nav-link" data-panel="services">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
      Our Services
    </div>
    <div class="nav-link" data-panel="settings">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 4.6a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 .6a1.65 1.65 0 0 0 1-1.51V-1a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
      Site Settings
    </div>

    <div class="nav-link" data-panel="profile">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
      My Profile
    </div>

    <% if(currentUserRole !== 'editor'){ %>
    <div class="nav-section">System</div>
    <div class="nav-link" data-panel="users">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      User Accounts
    </div>
    <div class="nav-link" data-panel="audit">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
      Audit Log
    </div>
    <% } %>
  </nav>

  <div class="sb-foot">
    <a href="/admin/logout" class="sb-logout">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
      Log Out
    </a>
  </div>
</aside>

<!-- ══════════════════════ MAIN ══════════════════════ -->
<div class="main">
  <div class="topbar">
    <div class="topbar-title" id="page-title">Overview</div>
    <div class="topbar-actions">
      <a href="/" target="_blank" class="view-site">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        View Live Site
      </a>
    </div>
  </div>

  <div class="content" id="main-content">

    <!-- ─────────────── OVERVIEW ─────────────── -->
    <div id="panel-overview" class="panel active">
      <div class="stats">
        <div class="stat">
          <div class="stat-icon si-blue"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div>
          <div class="stat-info"><p>Total Bookings</p><div class="stat-val" id="stat-bookings"><%= bookings.length %></div></div>
        </div>
        <div class="stat">
          <div class="stat-icon si-yellow"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
          <div class="stat-info"><p>Pending</p><div class="stat-val" id="stat-pending"><%= bookings.filter(function(b){return b.status==='Pending'}).length %></div></div>
        </div>
        <div class="stat">
          <div class="stat-icon si-green"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4"/></svg></div>
          <div class="stat-info"><p>Inquiries</p><div class="stat-val" id="stat-contacts"><%= contacts.length %></div></div>
        </div>
        <div class="stat">
          <div class="stat-icon si-purple"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg></div>
          <div class="stat-info"><p>System Users</p><div class="stat-val"><%= users.length %></div></div>
        </div>
        <div class="stat">
          <div class="stat-icon si-red"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 6h13M8 12h13M8 18h5"/></svg></div>
          <div class="stat-info"><p>Events</p><div class="stat-val"><%= events.length %></div></div>
        </div>
        <div class="stat">
          <div class="stat-icon si-blue"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="2" x2="22" y2="6"/><line x1="17" y1="3" x2="9" y2="11"/><path d="M12 8l-6 6H3v-3l6-6"/></svg></div>
          <div class="stat-info"><p>Vaccines</p><div class="stat-val"><%= vaccines.length %></div></div>
        </div>
      </div>

      <div class="g2-eq">
        <div class="card">
          <div class="card-head"><h3>Recent Appointments</h3><button class="btn btn-ghost btn-sm" onclick="switchPanel('bookings')">View All</button></div>
          <div class="card-body" style="padding:0">
            <% bookings.slice(0,6).forEach(function(b){ %>
            <div class="rec-item" style="padding:10px 18px">
              <div><div class="rec-name"><%= b.patient_name %></div><div class="rec-sub"><%= b.service %> · <%= b.appointment_date %></div></div>
              <span class="badge b-<%= b.status.toLowerCase() %>"><%= b.status %></span>
            </div>
            <% }) %>
            <% if(!bookings.length){ %><p style="padding:16px 18px;color:var(--muted);font-size:.83rem">No appointments yet.</p><% } %>
          </div>
        </div>
        <div class="card">
          <div class="card-head"><h3>Recent Inquiries</h3><button class="btn btn-ghost btn-sm" onclick="switchPanel('contacts')">View All</button></div>
          <div class="card-body" style="padding:0">
            <% contacts.slice(0,5).forEach(function(c){ %>
            <div class="rec-item" style="padding:10px 18px">
              <div><div class="rec-name"><%= c.name %></div><div class="rec-sub"><%= c.phone %></div></div>
              <span class="badge b-<%= c.status.toLowerCase() %>"><%= c.status %></span>
            </div>
            <% }) %>
            <% if(!contacts.length){ %><p style="padding:16px 18px;color:var(--muted);font-size:.83rem">No inquiries yet.</p><% } %>
          </div>
        </div>
      </div>

      <div class="g2-eq">
        <div class="card">
          <div class="card-head"><h3>Booking Trends</h3></div>
          <div class="card-body">
            <div class="chart-ph">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
              Chart visualization (plug in Chart.js)
            </div>
          </div>
        </div>
        <div class="card">
          <div class="card-head"><h3>Service Distribution</h3></div>
          <div class="card-body">
            <div class="chart-ph">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21.21 15.89A10 10 0 1 1 8 2.83"/><path d="M22 12A10 10 0 0 0 12 2v10z"/></svg>
              Chart visualization (plug in Chart.js)
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ─────────────── BOOKINGS ─────────────── -->
    <div id="panel-bookings" class="panel">
      <div class="card">
        <div class="card-head">
          <h3>Appointments</h3>
          <div class="filter-row">
            <button class="fb active" onclick="filterBookings('All')">All</button>
            <button class="fb" onclick="filterBookings('Pending')">Pending</button>
            <button class="fb" onclick="filterBookings('Confirmed')">Confirmed</button>
            <button class="fb" onclick="filterBookings('Completed')">Completed</button>
            <button class="fb" onclick="filterBookings('Cancelled')">Cancelled</button>
          </div>
        </div>
        <div class="tbl-wrap">
          <table>
            <thead><tr><th>Patient</th><th>Service</th><th>Date</th><th>Slot</th><th>Status</th><th>Actions</th></tr></thead>
            <tbody id="bookings-tbody">
            <% if(!bookings.length){ %>
              <tr class="no-rows"><td colspan="6" style="text-align:center;padding:28px;color:var(--muted)">No appointments recorded</td></tr>
            <% } %>
            <% bookings.forEach(function(b){ %>
              <tr id="brow-<%= b.id %>" class="brow" data-status="<%= b.status %>">
                <td><strong><%= b.patient_name %></strong><br><span style="font-size:.74rem;color:var(--muted)"><%= b.phone %></span></td>
                <td><%= b.service %></td>
                <td><%= b.appointment_date %></td>
                <td><%= b.time_slot %></td>
                <td><span class="badge b-<%= b.status.toLowerCase() %>" id="bst-<%= b.id %>"><%= b.status %></span></td>
                <td>
                  <div class="act-row">
                    <% if(b.status==='Pending'){ %>
                      <button class="btn btn-success btn-sm" onclick="bookingStatus(<%= b.id %>,'Confirmed')">Confirm</button>
                      <button class="btn btn-warning btn-sm" onclick="bookingStatus(<%= b.id %>,'Cancelled')">Cancel</button>
                    <% } else if(b.status==='Confirmed'){ %>
                      <button class="btn btn-primary btn-sm" onclick="bookingStatus(<%= b.id %>,'Completed')">Complete</button>
                    <% } %>
                    <% if(currentUserRole==='admin'||currentUserRole==='manager'){ %>
                      <button class="ib ib-del" onclick="delBooking(<%= b.id %>)" title="Delete">🗑</button>
                    <% } %>
                  </div>
                </td>
              </tr>
            <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- ─────────────── CONTACTS ─────────────── -->
    <div id="panel-contacts" class="panel">
      <div class="card">
        <div class="card-head"><h3>Contact Inquiries</h3></div>
        <div class="card-body" id="contacts-list">
          <% if(!contacts.length){ %>
            <p style="color:var(--muted)">No inquiries received yet.</p>
          <% } %>
          <% contacts.forEach(function(c){ %>
          <div class="inq-card" id="icard-<%= c.id %>">
            <div class="inq-head">
              <div class="inq-meta">
                <h5><%= c.name %></h5>
                <p><%= c.phone %><% if(c.email){ %> · <%= c.email %><% } %> · <%= new Date(c.created_at).toLocaleDateString() %></p>
              </div>
              <span class="badge b-<%= c.status.toLowerCase() %>" id="cst-<%= c.id %>"><%= c.status %></span>
            </div>
            <div class="inq-body"><%= c.message %></div>
            <div class="inq-foot">
              <% if(c.status==='Pending'){ %>
                <button class="btn btn-primary btn-sm" id="cbtn-<%= c.id %>" onclick="contactStatus(<%= c.id %>,'Replied')">Mark Replied</button>
              <% } %>
              <% if(currentUserRole==='admin'||currentUserRole==='manager'){ %>
                <button class="btn btn-danger btn-sm" onclick="delContact(<%= c.id %>)">Delete</button>
              <% } %>
            </div>
          </div>
          <% }) %>
        </div>
      </div>
    </div>

    <!-- ─────────────── EVENTS ─────────────── -->
    <div id="panel-events" class="panel">
      <div class="g2">
        <div>
          <div class="card">
            <div class="card-head"><h3>Events</h3><button class="btn btn-primary btn-sm" onclick="openEventModal(null)">+ New Event</button></div>
            <div class="tbl-wrap">
              <table>
                <thead><tr><th>Title</th><th>Category</th><th>Date</th><th>Status</th><th>Actions</th></tr></thead>
                <tbody id="events-tbody">
                <% if(!events.length){ %>
                  <tr><td colspan="5" style="text-align:center;padding:24px;color:var(--muted)">No events yet</td></tr>
                <% } %>
                <% events.forEach(function(ev){ %>
                  <tr id="evrow-<%= ev.id %>">
                    <td><strong style="font-size:.84rem"><%= ev.title %></strong></td>
                    <td><%
                      var catClass = {
                        'Vaccination Drive':'chip-vax','Health Camp':'chip-health',
                        'Seminar':'chip-sem','Workshop':'chip-work','Community Outreach':'chip-com'
                      }[ev.category]||'chip-gen';
                    %><span class="chip <%= catClass %>"><%= ev.category %></span></td>
                    <td style="font-size:.8rem;color:var(--muted)"><%= ev.event_date %></td>
                    <td><span class="badge <%= ev.is_published?'b-published':'b-draft' %>" id="evst-<%= ev.id %>"><%= ev.is_published?'Published':'Draft' %></span></td>
                    <td>
                      <div class="act-row">
                        <button class="ib ib-eye" onclick="togglePublish(<%= ev.id %>)" title="Toggle Publish">⊙</button>
                        <button class="ib ib-edit" onclick="openEventModal(<%= ev.id %>)" title="Edit">✎</button>
                        <% if(currentUserRole==='admin'||currentUserRole==='manager'){ %>
                          <button class="ib ib-del" onclick="delEvent(<%= ev.id %>)" title="Delete">🗑</button>
                        <% } %>
                      </div>
                    </td>
                  </tr>
                <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
        <div>
          <div class="card">
            <div class="card-head"><h3>Quick Stats</h3></div>
            <div class="card-body">
              <div style="display:flex;flex-direction:column;gap:10px">
                <div style="display:flex;justify-content:space-between;font-size:.84rem"><span style="color:var(--muted)">Total Events</span><strong><%= events.length %></strong></div>
                <div style="display:flex;justify-content:space-between;font-size:.84rem"><span style="color:var(--muted)">Published</span><strong style="color:var(--success)"><%= events.filter(function(e){return e.is_published}).length %></strong></div>
                <div style="display:flex;justify-content:space-between;font-size:.84rem"><span style="color:var(--muted)">Drafts</span><strong style="color:var(--warning)"><%= events.filter(function(e){return !e.is_published}).length %></strong></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ─────────────── VACCINES ─────────────── -->
    <div id="panel-vaccines" class="panel">
      <div class="g2">
        <div class="card">
          <div class="card-head"><h3>EPI Vaccine Schedule</h3><button class="btn btn-primary btn-sm" onclick="openVaccineModal(null)">+ Add Entry</button></div>
          <div class="tbl-wrap">
            <table>
              <thead><tr><th>#</th><th>Vaccine</th><th>Age</th><th>Days</th><th>Diseases</th><th>Actions</th></tr></thead>
              <tbody id="vaccines-tbody">
              <% if(!vaccines.length){ %>
                <tr><td colspan="5" style="text-align:center;padding:24px;color:var(--muted)">No entries yet</td></tr>
              <% } %>
              <% vaccines.forEach(function(v, vIdx){ %>
                <tr id="vrow-<%= v.id %>">
                  <td style="color:var(--muted);font-size:.78rem;font-weight:600"><%= vIdx+1 %></td>
                  <td><strong style="font-size:.84rem"><%= v.name %></strong></td>
                  <td><%= v.age_text %></td>
                  <td><span class="badge" style="background:#EEF4FF;color:var(--primary);font-size:.76rem"><%= v.offset_days %>d</span></td>
                  <td style="font-size:.76rem;color:var(--muted);max-width:180px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis"><%= v.diseases %></td>
                  <td>
                    <div class="act-row">
                      <button class="ib ib-edit" onclick="moveVaccine(<%= v.id %>,'up')" title="Move Up (same-day group)">↑</button>
                      <button class="ib ib-edit" onclick="moveVaccine(<%= v.id %>,'down')" title="Move Down (same-day group)">↓</button>
                      <button class="ib ib-edit" onclick="openVaccineModal(<%= v.id %>)" title="Edit">✎</button>
                      <% if(currentUserRole==='admin'||currentUserRole==='manager'){ %>
                        <button class="ib ib-del" onclick="delVaccine(<%= v.id %>)" title="Delete">🗑</button>
                      <% } %>
                    </div>
                  </td>
                </tr>
              <% }) %>
              </tbody>
            </table>
          </div>
        </div>
        <div class="card">
          <div class="card-head"><h3>EPI Coverage</h3></div>
          <div class="card-body">
            <div class="chart-ph">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
              Age group distribution
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ─────────────── SECTIONS ─────────────── -->
    <div id="panel-sections" class="panel">
      <div class="g2">
        <div class="card">
          <div class="card-head"><h3>Homepage Sections</h3><button class="btn btn-primary btn-sm" onclick="openSectionModal(null)">+ Add Section</button></div>
          <div class="card-body" id="sections-list">
            <% if(!sections.length){ %><p style="color:var(--muted)">No custom sections yet.</p><% } %>
            <% sections.forEach(function(s){ %>
            <div class="sec-item" id="srow-<%= s.id %>">
              <div class="sec-thumb">
                <% if(s.image_path){ %><img src="<%= s.image_path %>" alt=""><% } else { %>
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#CBD5E1" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                <% } %>
              </div>
              <div class="sec-info">
                <h5><%= s.title %></h5>
                <p><%= s.content.substring(0,70) %>...</p>
                <span class="badge" style="margin-top:4px;background:<%= s.is_visible?'#D1FAE5':'#FEE2E2' %>;color:<%= s.is_visible?'#065F46':'#991B1B' %>"><%= s.is_visible?'Visible':'Hidden' %></span>
              </div>
              <div class="sec-acts">
                <button class="ib ib-edit" onclick="moveSection(<%= s.id %>,'up')" title="Move Up">↑</button>
                <button class="ib ib-edit" onclick="moveSection(<%= s.id %>,'down')" title="Move Down">↓</button>
                <button class="ib ib-edit" onclick="openSectionModal(<%= s.id %>)" title="Edit">✎</button>
                <% if(currentUserRole==='admin'||currentUserRole==='manager'){ %>
                  <button class="ib ib-del" onclick="delSection(<%= s.id %>)" title="Delete">🗑</button>
                <% } %>
              </div>
            </div>
            <% }) %>
          </div>
        </div>
        <div class="card">
          <div class="card-head"><h3>Visibility Summary</h3></div>
          <div class="card-body">
            <div style="display:flex;flex-direction:column;gap:10px">
              <div style="display:flex;justify-content:space-between;font-size:.84rem"><span style="color:var(--muted)">Total Sections</span><strong><%= sections.length %></strong></div>
              <div style="display:flex;justify-content:space-between;font-size:.84rem"><span style="color:var(--muted)">Visible</span><strong style="color:var(--success)"><%= sections.filter(function(s){return s.is_visible}).length %></strong></div>
              <div style="display:flex;justify-content:space-between;font-size:.84rem"><span style="color:var(--muted)">Hidden</span><strong style="color:var(--danger)"><%= sections.filter(function(s){return !s.is_visible}).length %></strong></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ─────────────── RESOURCES ─────────────── -->
    <div id="panel-resources" class="panel">
      <div class="card">
        <div class="card-head">
          <h3>Health Resources & Publications</h3>
          <button class="btn btn-primary btn-sm" onclick="openResourceModal(null)">+ Add Resource</button>
        </div>
        <div class="tbl-wrap">
          <table>
            <thead><tr><th>Title</th><th>Type</th><th>File</th><th>Visible</th><th>Actions</th></tr></thead>
            <tbody id="resources-tbody">
            <% if(!resources.length){ %>
              <tr><td colspan="5" style="text-align:center;padding:28px;color:var(--muted)">No resources yet. Click "+ Add Resource" to create one.</td></tr>
            <% } %>
            <% resources.forEach(function(rc){ %>
              <tr id="rcrow-<%= rc.id %>">
                <td><strong style="font-size:.85rem"><%= rc.title %></strong><% if(rc.description){ %><br><span style="font-size:.74rem;color:var(--muted)"><%= rc.description.substring(0,60) %><%= rc.description.length>60?'...':'' %></span><% } %></td>
                <td><span class="badge" style="background:#EEF4FF;color:var(--primary);font-size:.7rem"><%= rc.type %></span></td>
                <td>
                  <% if(rc.file_path){ %>
                    <span class="badge" style="background:#D1FAE5;color:#065F46;font-size:.7rem">Attached</span>
                    <button class="btn-pdf-view" onclick="openPdf('<%= rc.file_path %>')" style="margin-left:6px;font-size:.74rem">View</button>
                  <% } else { %>
                    <span class="badge" style="background:#FEE2E2;color:#991B1B;font-size:.7rem">No File</span>
                  <% } %>
                </td>
                <td><span class="badge <%= rc.is_visible?'b-published':'b-draft' %>"><%= rc.is_visible?'Yes':'No' %></span></td>
                <td>
                  <div class="act-row">
                    <button class="ib ib-edit" onclick="openResourceModal(<%= rc.id %>)" title="Edit">✎</button>
                    <label class="ib ib-edit" title="Upload File" style="cursor:pointer">
                      📎
                      <input type="file" id="rfile-<%= rc.id %>" accept=".pdf,.doc,.docx" style="display:none" onchange="uploadResourceFile(<%= rc.id %>,this)">
                    </label>
                    <% if(rc.file_path&&(currentUserRole==='admin'||currentUserRole==='manager')){ %>
