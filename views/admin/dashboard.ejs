    <!-- ─────────────── SETTINGS ─────────────── -->
    <div id="panel-settings" class="panel">

      <!-- Image uploads -->
      <div class="card">
        <div class="card-head"><h3>Site Images & Media</h3></div>
        <div class="card-body">
          <div class="img-upload-grid">
            <% [
              {field:'hero_image',label:'Hero Banner'},
              {field:'service_vax_image',label:'EPI Service'},
              {field:'service_fp_image',label:'Family Planning'},
              {field:'service_anc_image',label:'Antenatal Care'},
              {field:'service_autism_image',label:'Autism Support'}
            ].forEach(function(img){ %>
            <div class="img-item">
              <label><%= img.label %></label>
              <div id="prev-<%= img.field %>">
                <% if(settings[img.field]){ %><img src="<%= settings[img.field] %>" class="img-prev" alt=""><% } else { %><div class="img-ph">No image set</div><% } %>
              </div>
              <div style="display:flex;gap:6px;margin-top:6px">
                <input type="file" id="fi-<%= img.field %>" accept=".jpg,.jpeg,.png,.webp" class="fc" style="flex:1;font-size:.74rem">
                <button class="btn btn-ghost btn-sm" onclick="uploadSettingImg('<%= img.field %>')">Upload</button>
              </div>
            </div>
            <% }) %>
          </div>
          <p style="font-size:.74rem;color:var(--muted);margin-top:10px">JPG, PNG, WEBP. Max 5MB.</p>
        </div>
      </div>

      <!-- Site settings form -->
      <form id="settings-form">
        <div class="card">
          <div class="card-head"><h3>Hero Section</h3></div>
          <div class="card-body">
            <div class="fg"><label>Hero Title</label><input type="text" name="hero_title" value="<%= settings.hero_title||'' %>" class="fc"></div>
            <div class="fg"><label>Hero Description</label><textarea name="hero_description" rows="3" class="fc"><%= settings.hero_description||'' %></textarea></div>
          </div>
        </div>

        <div class="card">
          <div class="card-head"><h3>Contact Information</h3></div>
          <div class="card-body">
            <div class="fgrid">
              <div class="fg"><label>Primary Phone</label><input type="text" name="contact_phone" value="<%= settings.contact_phone||'' %>" class="fc"></div>
              <div class="fg"><label>Alternate Phone</label><input type="text" name="contact_phone_alt" value="<%= settings.contact_phone_alt||'' %>" class="fc"></div>
              <div class="fg"><label>Primary Email</label><input type="email" name="contact_email" value="<%= settings.contact_email||'' %>" class="fc"></div>
              <div class="fg"><label>Support Email</label><input type="email" name="contact_email_alt" value="<%= settings.contact_email_alt||'' %>" class="fc"></div>
              <div class="fg span2"><label>Address</label><input type="text" name="contact_address" value="<%= settings.contact_address||'' %>" class="fc"></div>
              <div class="fg"><label>Weekday Hours</label><input type="text" name="opening_hours_weekdays" value="<%= settings.opening_hours_weekdays||'' %>" class="fc"></div>
              <div class="fg"><label>Weekend Hours</label><input type="text" name="opening_hours_weekend" value="<%= settings.opening_hours_weekend||'' %>" class="fc"></div>
            </div>
          </div>
        </div>

        <div class="card">
          <div class="card-head"><h3>About Section</h3></div>
          <div class="card-body">
            <div class="fgrid">
              <div class="fg span2"><label>Subtitle</label><input type="text" name="about_subtitle" value="<%= settings.about_subtitle||'' %>" class="fc"></div>
              <div class="fg"><label>Paragraph 1</label><textarea name="about_paragraph_1" rows="3" class="fc"><%= settings.about_paragraph_1||'' %></textarea></div>
              <div class="fg"><label>Paragraph 2</label><textarea name="about_paragraph_2" rows="3" class="fc"><%= settings.about_paragraph_2||'' %></textarea></div>
              <div class="fg"><label>Children Stat</label><input type="text" name="stat_children" value="<%= settings.stat_children||'' %>" class="fc"></div>
              <div class="fg"><label>Staff Stat</label><input type="text" name="stat_staff" value="<%= settings.stat_staff||'' %>" class="fc"></div>
              <div class="fg"><label>Satisfaction Stat</label><input type="text" name="stat_satisfaction" value="<%= settings.stat_satisfaction||'' %>" class="fc"></div>
            </div>
          </div>
        </div>

        <div style="display:flex;justify-content:flex-end;margin-bottom:18px">
          <button type="submit" class="btn btn-primary" id="save-settings-btn" style="padding:10px 28px">Save All Settings</button>
        </div>
      </form>

      <!-- Resource PDFs managed via Resources panel -->
    </div>

    <!-- ─────────────── USERS ─────────────── -->
    <!-- ─────────────── MY PROFILE ─────────────── -->
    <div id="panel-profile" class="panel">
      <div class="card" style="max-width:460px">
        <div class="card-head"><h3>My Profile</h3></div>
        <div class="card-body">
          <div class="fg">
            <label>Username</label>
            <input type="text" class="fc" value="<%= currentUser %>" disabled style="background:#f8fafc;color:var(--muted)">
          </div>
          <div class="fg">
            <label>Role</label>
            <div style="padding:6px 0"><span class="badge b-<%= currentUserRole %>" style="font-size:.82rem;text-transform:capitalize"><%= currentUserRole %></span></div>
          </div>
          <hr style="border:none;border-top:1px solid var(--border);margin:16px 0">
          <p style="font-size:.84rem;color:var(--muted);margin-bottom:14px">Change your account password:</p>
          <button class="btn btn-primary" onclick="openPwdModal(<%= currentUserId %>,'<%= currentUser %>')">&#x1F511; Change My Password</button>
        </div>
      </div>
    </div>

    <% if(currentUserRole !== 'editor'){ %>
    <div id="panel-users" class="panel">
      <div class="g2">
        <div class="card">
          <div class="card-head"><h3>System Users</h3></div>
          <div class="tbl-wrap">
            <table>
              <thead><tr><th>Username</th><th>Role</th><th>Created</th><th>Actions</th></tr></thead>
              <tbody id="users-tbody">
              <% users.forEach(function(u){ %>
                <tr id="urow-<%= u.id %>">
                  <td><strong><%= u.username %></strong></td>
                  <td><span class="badge b-<%= u.role %>"><%= u.role %></span></td>
                  <td style="color:var(--muted);font-size:.78rem"><%= new Date(u.created_at).toLocaleDateString() %></td>
                  <td>
                    <div class="act-row">
                      <% if(currentUserRole==='admin'||u.id===currentUserId){ %>
                        <button class="ib ib-key" onclick="openPwdModal(<%= u.id %>,'<%= u.username %>')" title="Change Password">🔑</button>
                      <% } %>
                      <% if(currentUserRole==='admin'&&u.id!==currentUserId){ %>
                        <button class="ib ib-del" onclick="delUser(<%= u.id %>)" title="Delete">🗑</button>
                      <% } %>
                    </div>
                  </td>
                </tr>
              <% }) %>
              </tbody>
            </table>
          </div>
        </div>

        <% if(currentUserRole==='admin'){ %>
        <div class="card">
          <div class="card-head"><h3>Create New User</h3></div>
          <div class="card-body">
            <div id="user-create-err" class="alert alert-danger"></div>
            <div class="fg"><label>Username *</label><input type="text" id="nu-username" class="fc" placeholder="e.g. nurse_rahima"></div>
            <div class="fg"><label>Password * (min 6 chars)</label><input type="password" id="nu-password" class="fc" placeholder="••••••••"></div>
            <div class="fg">
              <label>Role *</label>
              <select id="nu-role" class="fc">
                <option value="editor">Editor — Edit content only</option>
                <option value="manager">Manager — Edit &amp; delete content</option>
                <option value="admin">Admin — Full access</option>
              </select>
            </div>
            <button class="btn btn-primary" style="width:100%;margin-top:4px" onclick="createUser()">Create Account</button>
          </div>
        </div>
        <% } else { %>
        <div class="card">
          <div class="card-head"><h3>Permissions</h3></div>
          <div class="card-body"><p style="color:var(--muted);font-size:.84rem">Only <strong>Admins</strong> can create new user accounts. Contact your administrator.</p></div>
        </div>
        <% } %>
      </div>
    </div>

    <!-- ─────────────── AUDIT LOG ─────────────── -->
    <div id="panel-audit" class="panel">
      <div class="card">
        <div class="card-head"><h3>Audit Log</h3><span style="font-size:.78rem;color:var(--muted)">Last 100 actions · Read-only</span></div>
        <div class="card-body">
          <% if(!auditLogs.length){ %><p style="color:var(--muted)">No activity recorded yet.</p><% } %>
          <% auditLogs.forEach(function(log){ %>
          <%
            var iconClass = log.action.includes('DELETE')?'al-delete':log.action.includes('CREATE')?'al-create':log.action.includes('LOGIN')||log.action.includes('LOGOUT')?'al-login':'al-update';
            var icon = log.action.includes('DELETE')?'🗑':log.action.includes('CREATE')?'✦':log.action.includes('LOGIN')?'🔐':'✎';
          %>
          <div class="al-row">
            <div class="al-icon <%= iconClass %>"><%= icon %></div>
            <div class="al-info">
              <p><strong><%= log.username %></strong> · <span style="color:var(--primary);font-weight:600"><%= log.action %></span><% if(log.target_table){ %> on <em><%= log.target_table %></em><% if(log.target_id){ %> #<%= log.target_id %><% } %><% } %><% if(log.details){ %> · <span style="color:var(--muted)"><%= log.details %></span><% } %></p>
              <small><%= new Date(log.created_at).toLocaleString() %><% if(log.ip){ %> · <%= log.ip %><% } %></small>
            </div>
          </div>
          <% }) %>
        </div>
      </div>
    </div>
    <% } %> <%# end: editor guard for panel-users + panel-audit %>

  </div><!-- /content -->
</div><!-- /main -->

