      <div class="fgrid">
        <div class="fg"><label>Cover Image <span style="color:var(--muted);font-weight:400">(.jpg/.png)</span></label><input type="file" id="e-image" accept=".jpg,.jpeg,.png,.webp" class="fc"></div>
        <div class="fg"><label>PDF Brochure <span style="color:var(--muted);font-weight:400">(.pdf)</span></label><input type="file" id="e-pdf" accept=".pdf" class="fc"></div>
      </div>
      <label class="inline-cb" style="margin-top:4px"><input type="checkbox" id="e-published"> Publish immediately</label>
    </div>
    <div class="modal-foot"><button class="btn btn-ghost" onclick="closeModal('modal-event')">Cancel</button><button class="btn btn-primary" onclick="saveEvent()">Save Event</button></div>
  </div>
</div>

<!-- Toast container -->
<div id="toast"></div>

<!-- Embedded data -->
<script type="application/json" id="d-vaccines"><%- JSON.stringify(vaccines).replace(/<\//g,'<\\/') %></script>
<script type="application/json" id="d-sections"><%- JSON.stringify(sections).replace(/<\//g,'<\\/') %></script>
<script type="application/json" id="d-events"><%- JSON.stringify(events).replace(/<\//g,'<\\/') %></script>
<script type="application/json" id="d-resources"><%- JSON.stringify(resources).replace(/<\//g,'<\\/') %></script>
<script>var CURRENT_USER_ROLE='<%= currentUserRole %>';var CURRENT_USER_ID=<%= currentUserId %>;</script>
<script src="/admin.js?v=<%= Date.now() %>"></script>
<script>
  // BFCache guard
  window.addEventListener('pageshow',function(e){if(e.persisted)window.location.reload();});
  // Modal close on overlay click
  document.querySelectorAll('.modal-overlay').forEach(function(o){
    o.addEventListener('click',function(e){if(e.target===o)o.classList.remove('open');});
  });
</script>
</body>
</html>
