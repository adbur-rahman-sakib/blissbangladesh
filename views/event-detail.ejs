<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= event.title %> | Bliss Bangladesh</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
  <style>
    body { background: #F8FAFC; margin: 0; font-family: 'Inter', sans-serif; }
    .page-nav { background: #fff; border-bottom: 1px solid #E2E8F0; padding: 0 60px; }
    .page-nav-inner { max-width: 900px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; height: 64px; }
    .page-nav-brand { font-family: 'Outfit', sans-serif; font-weight: 800; font-size: 1.15rem; color: #0040A5; text-decoration: none; }
    .page-nav-links { display: flex; gap: 28px; }
    .page-nav-links a { font-family: 'Inter', sans-serif; font-size: 0.9rem; color: #475569; text-decoration: none; font-weight: 500; }
    .page-nav-links a:hover { color: #0040A5; }
    .event-detail-wrap { max-width: 900px; margin: 0 auto; padding: 48px 24px 80px; }
    .back-link { display: inline-flex; align-items: center; gap: 6px; color: #0040A5; font-size: 0.88rem; font-weight: 600; text-decoration: none; margin-bottom: 28px; }
    .back-link:hover { color: #002d80; }
    .event-header { margin-bottom: 32px; }
    .event-category-badge { display: inline-block; padding: 4px 14px; border-radius: 14px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.5px; text-transform: uppercase; margin-bottom: 14px; }
    .cat-vaccination    { background: #DBEAFE; color: #1D4ED8; }
    .cat-health-camp    { background: #D1FAE5; color: #065F46; }
    .cat-seminar        { background: #FEF3C7; color: #92400E; }
    .cat-workshop       { background: #F3E8FF; color: #6B21A8; }
    .cat-community      { background: #FFE4E6; color: #9F1239; }
    .cat-general        { background: #F1F5F9; color: #475569; }
    .event-title { font-family: 'Outfit', sans-serif; font-size: 2.2rem; font-weight: 800; color: #0F172A; line-height: 1.25; margin-bottom: 20px; }
    .event-meta-bar { display: flex; flex-wrap: wrap; gap: 20px; padding: 16px 0; border-top: 1px solid #E2E8F0; border-bottom: 1px solid #E2E8F0; margin-bottom: 32px; }
    .event-meta-item { display: flex; align-items: center; gap: 8px; font-size: 0.9rem; color: #475569; }
    .event-meta-item svg { color: #0040A5; flex-shrink: 0; }
    .event-meta-label { font-weight: 600; color: #0F172A; }
    .event-img-wrap { display: block; cursor: zoom-in; border-radius: 14px; overflow: hidden; margin-bottom: 36px; background: #EEF4FF; text-align: center; }
    .event-img-wrap:focus { outline: 2px solid #0040A5; }
    .event-cover-img { width: 100%; height: auto; display: block; object-fit: contain; pointer-events: none; user-select: none; -webkit-user-drag: none; border-radius: 14px; }
    /* Lightbox */
    #ev-lightbox { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.93); z-index: 9999; align-items: center; justify-content: center; cursor: zoom-out; }
    #ev-lightbox.open { display: flex; }
    #ev-lightbox img { max-width: 95vw; max-height: 92vh; object-fit: contain; border-radius: 6px; pointer-events: none; user-select: none; -webkit-user-drag: none; }
    #ev-lb-close { position: absolute; top: 14px; right: 18px; background: rgba(255,255,255,0.15); border: none; color: #fff; font-size: 1.6rem; width: 40px; height: 40px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; line-height: 1; }
    #ev-lb-close:hover { background: rgba(255,255,255,0.28); }
    .event-description { font-size: 1rem; line-height: 1.8; color: #334155; white-space: pre-line; margin-bottom: 48px; }
    .pdf-section { background: #fff; border: 1px solid #E2E8F0; border-radius: 14px; overflow: hidden; margin-bottom: 40px; }
    .pdf-section-header { padding: 18px 24px; border-bottom: 1px solid #E2E8F0; display: flex; align-items: center; justify-content: space-between; }
    .pdf-section-header h3 { font-family: 'Outfit', sans-serif; font-size: 1rem; font-weight: 700; color: #0F172A; margin: 0; display: flex; align-items: center; gap: 8px; }
    .pdf-download-btn { display: inline-flex; align-items: center; gap: 6px; padding: 8px 18px; background: #0040A5; color: #fff; border-radius: 8px; font-size: 0.85rem; font-weight: 600; text-decoration: none; font-family: 'Inter', sans-serif; }
    .pdf-download-btn:hover { background: #002d80; }
    .pdf-viewer { width: 100%; height: 700px; border: none; display: block; }
    .pdf-fallback { padding: 40px; text-align: center; color: #64748B; }
    /* Share section */
    .share-section { border-top: 1px solid #E2E8F0; padding-top: 32px; margin-bottom: 40px; }
    .share-section h4 { font-family: 'Outfit', sans-serif; font-size: 1rem; font-weight: 700; color: #0F172A; margin: 0 0 20px; }
    .share-btn-trigger { display: inline-flex; align-items: center; gap: 8px; padding: 10px 22px; background: #0040A5; color: #fff; border: none; border-radius: 24px; font-family: 'Inter', sans-serif; font-size: 0.88rem; font-weight: 600; cursor: pointer; transition: background 0.15s; }
    .share-btn-trigger:hover { background: #002d80; }
    /* Share modal */
    #share-overlay { display: none; position: fixed; inset: 0; background: rgba(15,23,42,0.55); z-index: 8000; align-items: center; justify-content: center; padding: 20px; }
    #share-overlay.open { display: flex; }
    #share-modal { background: #fff; border-radius: 18px; padding: 32px 28px 28px; width: 100%; max-width: 460px; position: relative; box-shadow: 0 20px 60px rgba(0,0,0,0.18); animation: shareIn 0.2s ease; }
    @keyframes shareIn { from { opacity:0; transform: scale(0.95) translateY(8px); } to { opacity:1; transform: scale(1) translateY(0); } }
    #share-modal h3 { font-family: 'Outfit', sans-serif; font-size: 1.1rem; font-weight: 700; color: #0F172A; margin: 0 0 24px; }
    #share-close { position: absolute; top: 16px; right: 16px; background: #F1F5F9; border: none; width: 32px; height: 32px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; color: #64748B; font-size: 1rem; }
    #share-close:hover { background: #E2E8F0; color: #0F172A; }
    .share-icons { display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 28px; }
    .share-icon-btn { display: flex; flex-direction: column; align-items: center; gap: 7px; text-decoration: none; cursor: pointer; }
    .share-icon-circle { width: 56px; height: 56px; border-radius: 50%; border: 1.5px solid #E2E8F0; display: flex; align-items: center; justify-content: center; transition: border-color 0.15s, box-shadow 0.15s; background: #F8FAFC; }
    .share-icon-btn:hover .share-icon-circle { border-color: currentColor; box-shadow: 0 4px 14px rgba(0,0,0,0.1); }
    .share-icon-name { font-family: 'Inter', sans-serif; font-size: 0.72rem; color: #64748B; font-weight: 500; }
    .share-copy-row { display: flex; align-items: center; gap: 0; border: 1.5px solid #E2E8F0; border-radius: 10px; overflow: hidden; }
    .share-copy-url { flex: 1; padding: 10px 14px; font-family: 'Inter', sans-serif; font-size: 0.8rem; color: #475569; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; background: #F8FAFC; border: none; outline: none; }
    .share-copy-btn { flex-shrink: 0; padding: 10px 18px; background: none; border: none; border-left: 1.5px solid #E2E8F0; font-family: 'Inter', sans-serif; font-size: 0.82rem; font-weight: 600; color: #0040A5; cursor: pointer; white-space: nowrap; }
    .share-copy-btn:hover { color: #002d80; background: #F0F7FF; }
    .share-copy-label { font-family: 'Inter', sans-serif; font-size: 0.8rem; color: #94A3B8; margin-bottom: 8px; }
    @media (max-width: 600px) {
      .page-nav { padding: 0 20px; }
      .event-detail-wrap { padding: 28px 16px 60px; }
      .event-title { font-size: 1.5rem; }
      .pdf-viewer { height: 400px; }
    }
  </style>
</head>
<body>
  <nav class="page-nav">
    <div class="page-nav-inner">
      <a href="/" class="page-nav-brand">Bliss Bangladesh</a>
      <div class="page-nav-links">
        <a href="/">Home</a>
        <a href="/events">Events</a>
        <a href="/#contact">Contact</a>
      </div>
    </div>
  </nav>

  <div class="event-detail-wrap">
    <a href="/events" class="back-link">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
      Back to Events
    </a>

    <div class="event-header">
      <%
        const catClass = {
          'Vaccination Drive': 'cat-vaccination',
          'Health Camp': 'cat-health-camp',
          'Seminar': 'cat-seminar',
          'Workshop': 'cat-workshop',
          'Community Outreach': 'cat-community',
        }[event.category] || 'cat-general';
        const dateStr = new Date(event.event_date).toLocaleDateString('en-GB', { weekday:'long', day:'numeric', month:'long', year:'numeric' });
      %>
      <span class="event-category-badge <%= catClass %>"><%= event.category %></span>
      <h1 class="event-title"><%= event.title %></h1>

      <div class="event-meta-bar">
        <div class="event-meta-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          <div><span class="event-meta-label">Date</span><br><%= dateStr %></div>
        </div>
        <% if (event.event_time) { %>
        <div class="event-meta-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <div><span class="event-meta-label">Time</span><br><%= event.event_time %></div>
        </div>
        <% } %>
        <% if (event.location) { %>
        <div class="event-meta-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <div><span class="event-meta-label">Location</span><br><%= event.location %></div>
        </div>
        <% } %>
      </div>
    </div>

    <% if (event.cover_image) { %>
      <div class="event-img-wrap" role="button" tabindex="0" aria-label="View full image"
           onclick="evLbOpen(this)" onkeydown="if(event.key==='Enter')evLbOpen(this)"
           oncontextmenu="return false">
        <img src="<%= event.cover_image %>" alt="<%= event.title %>" class="event-cover-img" draggable="false">
      </div>
    <% } %>

    <div class="event-description"><%= event.description %></div>

    <% if (event.pdf_path) { %>
    <div class="pdf-section">
      <div class="pdf-section-header">
        <h3>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#E53935" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          Event Document / Brochure
        </h3>
        <a href="<%= event.pdf_path %>" download class="pdf-download-btn">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Download PDF
        </a>
      </div>
      <iframe class="pdf-viewer" src="<%= event.pdf_path %>#toolbar=1&navpanes=0" title="Event Document">
        <div class="pdf-fallback">
          <p>PDF preview not supported in your browser.</p>
          <a href="<%= event.pdf_path %>" download class="pdf-download-btn">Download PDF instead</a>
        </div>
      </iframe>
    </div>
    <% } %>

    <!-- Share section -->
    <div class="share-section">
      <h4>Share this Event</h4>
      <button class="share-btn-trigger" onclick="openShareModal()">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
        Share
      </button>
    </div>

    <a href="/events" class="back-link" style="margin-top: 16px;">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
      Back to All Events
    </a>
  </div>

  <!-- Share Modal -->
  <div id="share-overlay" onclick="if(event.target===this)closeShareModal()">
    <div id="share-modal">
      <button id="share-close" onclick="closeShareModal()" aria-label="Close">&#x2715;</button>
      <h3>Share this Event</h3>
      <div class="share-icons">
        <a class="share-icon-btn" id="share-fb" href="#" target="_blank" rel="noopener noreferrer" aria-label="Share on Facebook">
          <div class="share-icon-circle" style="color:#1877F2">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="#1877F2" stroke="none"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </div>
          <span class="share-icon-name">Facebook</span>
        </a>
        <a class="share-icon-btn" id="share-wa" href="#" target="_blank" rel="noopener noreferrer" aria-label="Share on WhatsApp">
          <div class="share-icon-circle" style="color:#25D366">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="#25D366" stroke="none"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.136.562 4.14 1.54 5.876L0 24l6.306-1.517A11.954 11.954 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.893 0-3.667-.51-5.19-1.4l-.37-.22-3.742.9.934-3.64-.242-.374A9.96 9.96 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
          </div>
          <span class="share-icon-name">WhatsApp</span>
        </a>
        <a class="share-icon-btn" id="share-tw" href="#" target="_blank" rel="noopener noreferrer" aria-label="Share on Twitter/X">
          <div class="share-icon-circle" style="color:#000">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="#000" stroke="none"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.747l7.73-8.835L1.254 2.25H8.08l4.259 5.63L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/></svg>
          </div>
          <span class="share-icon-name">Twitter / X</span>
        </a>
        <a class="share-icon-btn" id="share-li" href="#" target="_blank" rel="noopener noreferrer" aria-label="Share on LinkedIn">
          <div class="share-icon-circle" style="color:#0A66C2">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="#0A66C2" stroke="none"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </div>
          <span class="share-icon-name">LinkedIn</span>
        </a>
      </div>
      <p class="share-copy-label">Or copy link</p>
      <div class="share-copy-row">
        <input id="share-url-input" class="share-copy-url" type="text" readonly>
        <button class="share-copy-btn" id="share-copy-btn" onclick="copyShareLink()">Copy</button>
      </div>
    </div>
  </div>

  <script>
    var _shareUrl = window.location.href;
    var _shareTitle = encodeURIComponent('<%= event.title.replace(/'/g, "\\'") %>');

    function openShareModal() {
      document.getElementById('share-url-input').value = _shareUrl;
      var enc = encodeURIComponent(_shareUrl);
      document.getElementById('share-fb').href = 'https://www.facebook.com/sharer/sharer.php?u=' + enc;
      document.getElementById('share-wa').href = 'https://wa.me/?text=' + _shareTitle + '%20' + enc;
      document.getElementById('share-tw').href = 'https://twitter.com/intent/tweet?url=' + enc + '&text=' + _shareTitle;
      document.getElementById('share-li').href = 'https://www.linkedin.com/sharing/share-offsite/?url=' + enc;
      document.getElementById('share-overlay').classList.add('open');
      document.body.style.overflow = 'hidden';
    }
    function closeShareModal() {
      document.getElementById('share-overlay').classList.remove('open');
      document.body.style.overflow = '';
      document.getElementById('share-copy-btn').textContent = 'Copy';
    }
    function copyShareLink() {
      navigator.clipboard.writeText(_shareUrl).then(function() {
        var btn = document.getElementById('share-copy-btn');
        btn.textContent = 'Copied!';
        setTimeout(function() { btn.textContent = 'Copy'; }, 2000);
      }).catch(function() {
        document.getElementById('share-url-input').select();
        document.execCommand('copy');
      });
    }
    document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeShareModal(); });
  </script>
  <!-- Lightbox -->
  <div id="ev-lightbox" onclick="evLbClose()" oncontextmenu="return false">
    <button id="ev-lb-close" onclick="evLbClose();event.stopPropagation()" aria-label="Close">&#x2715;</button>
    <img id="ev-lb-img" src="" alt="">
  </div>
  <script>
    function evLbOpen(wrap) {
      var img = wrap.querySelector('img');
      document.getElementById('ev-lb-img').src = img.src;
      document.getElementById('ev-lb-img').alt = img.alt;
      document.getElementById('ev-lightbox').classList.add('open');
      document.body.style.overflow = 'hidden';
    }
    function evLbClose() {
      document.getElementById('ev-lightbox').classList.remove('open');
      document.body.style.overflow = '';
    }
    document.addEventListener('keydown', function(e) { if (e.key === 'Escape') evLbClose(); });
  </script>
</body>
</html>
