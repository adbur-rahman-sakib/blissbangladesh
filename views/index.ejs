<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Bliss Bangladesh - Authorized EPI & Family Planning Center. Providing trusted immunization and family planning services for a healthier tomorrow.">
  <title>Bliss Bangladesh | Care. Compassion. Community.</title>
  
  <!-- Modern Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  
  <!-- CSS Stylesheet -->
  <link rel="stylesheet" href="styles.css">
</head>
<body>

  <!-- Header Section -->
  <header class="header">
    <div class="container header-container">
      <!-- Logo -->
      <a href="#" class="logo-area" id="home-logo">
        <div class="logo-icon">
          <img src="/images/logo.png" alt="Bliss Bangladesh Logo" style="height:100px;width:auto;display:block;">
        </div>
        <div class="logo-text">
          <span class="logo-title">Bliss Bangladesh</span>
          <span class="logo-tagline">Care. Compassion. Community.</span>
        </div>
      </a>

      <!-- Navigation Menu -->
      <nav class="nav-menu" id="navMenu">
        <ul class="nav-list">
          <li><a href="#" class="nav-link active" data-sec="hero">Home</a></li>
          <li><a href="#about" class="nav-link" data-sec="about">About Us</a></li>
          <li><a href="#services" class="nav-link" data-sec="services">Services</a></li>
          <li><a href="#schedules" class="nav-link" data-sec="schedules">Schedules</a></li>
          <li><a href="#resources" class="nav-link" data-sec="resources">Resources</a></li>
          <li><a href="#events" class="nav-link" data-sec="events">Events</a></li>
          <li><a href="#contact" class="nav-link" data-sec="contact">Contact</a></li>
        </ul>
      </nav>

      <!-- Contact Button & Mobile Toggle -->
      <div class="header-actions">
        <a href="tel:<%= settings.contact_phone.replace(/\s+/g, '') %>" class="btn btn-phone btn-desktop">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          <span><%= settings.contact_phone %></span>
        </a>
        <button class="hamburger" id="hamburgerBtn" aria-label="Toggle Menu">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </div>
  </header>

  <!-- Hero Section -->
  <section class="hero-section" id="hero">
    <div class="container hero-container">
      <!-- Hero Left: Content -->
      <div class="hero-content">
        <div class="badge-authorized">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="badge-icon">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
          <span>Authorized EPI & Family Planning Center</span>
        </div>
        
        <h1 class="hero-title"><%- settings.hero_title %></h1>
        <p class="hero-description">
          <%= settings.hero_description %>
        </p>

        <div class="hero-buttons">
          <button class="btn btn-primary" id="openBookingBtn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
              <line x1="16" y1="2" x2="16" y2="6"/>
              <line x1="8" y1="2" x2="8" y2="6"/>
              <line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
            Book Appointment
          </button>
          <button class="btn btn-secondary" id="openScheduleBtn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/>
              <polyline points="10 9 9 9 8 9"/>
            </svg>
            Vaccine Schedule
          </button>
        </div>

        <!-- Hero Highlights -->
        <div class="hero-highlights">
          <div class="highlight-item">
            <div class="highlight-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                <polyline points="9 11 11 13 15 9"/>
              </svg>
            </div>
            <div class="highlight-text">
              <h4>Authorized</h4>
              <p>EPI Center</p>
            </div>
          </div>
          <div class="highlight-item">
            <div class="highlight-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
            </div>
            <div class="highlight-text">
              <h4>Expert</h4>
              <p>Healthcare Team</p>
            </div>
          </div>
          <div class="highlight-item">
            <div class="highlight-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
              </svg>
            </div>
            <div class="highlight-text">
              <h4>Compassionate</h4>
              <p>Care for All</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Hero Right: Image & Decorative elements -->
      <div class="hero-image-area">
        <!-- Plus symbols backgrounds -->
        <div class="deco-plus deco-plus-1">+</div>
        <div class="deco-plus deco-plus-2">+</div>
        
        <!-- Dots grid pattern -->
        <div class="deco-dots"></div>

        <!-- Main Image Container -->
        <div class="image-wrapper">
          <img src="<%= settings.hero_image || '/assets/images/hero.png' %>" alt="Healthy South Asian mother smiling and holding her happy child" class="hero-image">
          
          <!-- Glass Card Overlay -->
          <div class="glass-card-priority">
            <div class="priority-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                <line x1="12" y1="8" x2="12" y2="16"/>
                <line x1="8" y1="12" x2="16" y2="12"/>
              </svg>
            </div>
            <div class="priority-info">
              <span class="priority-label">Your Health</span>
              <span class="priority-value">Our Priority</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Authorization Banner -->
  <section class="auth-banner-section">
    <div class="container auth-banner-container">
      <div class="auth-logos">
        <img src="/images/dscc-logo-web.png" alt="Dhaka South City Corporation" class="auth-logo" onerror="this.style.display='none'">
        <img src="/images/epi-logo-web.png"  alt="EPI Bangladesh"              class="auth-logo" onerror="this.style.display='none'">
      </div>
      <div class="auth-divider"></div>
      <div class="auth-text">
        <div class="auth-verified-badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            <polyline points="9 11 11 13 15 9"/>
          </svg>
          Officially Authorized
        </div>
        <p class="auth-statement">
          Bliss Bangladesh is an officially authorized <strong>Expanded Program on Immunization (EPI)</strong> center operating under the supervision of the <strong>Dhaka South City Corporation (DSCC)</strong>.
        </p>
      </div>
    </div>
  </section>

  <!-- About Us Section -->
  <section class="about-section" id="about">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">About Us</span>
        <h2 class="section-title"><%= settings.about_subtitle %></h2>
      </div>
      <div class="about-grid">
        <div class="about-text-content">
          <h3>Empowering health through trusted clinical care and family support</h3>
          <p><%= settings.about_paragraph_1 %></p>
          <p><%= settings.about_paragraph_2 %></p>
          <div class="stats-grid">
            <div class="stat-card">
              <span class="stat-num"><%= settings.stat_children %></span>
              <span class="stat-desc">Children Immunized</span>
            </div>
            <div class="stat-card">
              <span class="stat-num"><%= settings.stat_staff %></span>
              <span class="stat-desc">Expert Doctors & Nurses</span>
            </div>
            <div class="stat-card">
              <span class="stat-num"><%= settings.stat_satisfaction %></span>
              <span class="stat-desc">Satisfaction Rate</span>
            </div>
          </div>
        </div>
        <div class="about-features-graphic">
          <div class="feature-item-box">
            <div class="feature-box-icon pink-bg">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E53935" stroke-width="2.5">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                <polyline points="22 4 12 14.01 9 11.01"/>
              </svg>
            </div>
            <div class="feature-box-desc">
              <h4>Government Authorized</h4>
              <p><%= settings.feature_epi_desc %></p>
            </div>
          </div>
          <div class="feature-item-box">
            <div class="feature-box-icon blue-bg">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#0040A5" stroke-width="2.5">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
              </svg>
            </div>
            <div class="feature-box-desc">
              <h4>100% Confidentiality</h4>
              <p><%= settings.feature_confidentiality_desc %></p>
            </div>
          </div>
          <div class="feature-item-box">
            <div class="feature-box-icon gold-bg">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#FFB300" stroke-width="2.5">
                <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
              </svg>
            </div>
            <div class="feature-box-desc">
              <h4>Affordable Plans</h4>
              <p><%= settings.feature_affordability_desc %></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="services-section" id="services">
    <div class="container">
      <div class="services-header text-center">
        <span class="services-tag">Our Services</span>
        <h2 class="services-title">Care You Can Count On</h2>
      </div>

      <div class="services-grid">
        <!-- Service Card 1 -->
        <div class="service-card" data-service-id="vaccination">
          <div class="card-badge">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <div class="service-icon-wrapper">
            <% if (settings.service_vax_image) { %>
              <img src="<%= settings.service_vax_image %>" alt="EPI Vaccination" class="service-icon-img">
            <% } else { %>
            <!-- Syringe Icon -->
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#0040A5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="18" y1="2" x2="22" y2="6"/>
              <line x1="14" y1="6" x2="18" y2="10"/>
              <line x1="17" y1="3" x2="9" y2="11"/>
              <path d="M12 8l-6 6H3v-3l6-6"/>
              <line x1="11" y1="13" x2="5" y2="19"/>
              <line x1="5" y1="19" x2="2" y2="22"/>
              <line x1="13" y1="9" x2="15" y2="11"/>
              <line x1="10" y1="12" x2="12" y2="14"/>
            </svg>
            <% } %>
          </div>
          <h3 class="service-name">EPI Vaccination</h3>
          <p class="service-desc"><%= settings.service_vax_desc %></p>
          <button class="learn-more-btn" data-service="vaccination">
            Learn More 
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="arrow-icon">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </button>
        </div>

        <!-- Service Card: Private Vaccination (NEW) -->
        <div class="service-card" id="pvtVaxCard" data-service-id="private-vaccination">
          <div class="card-badge">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <div class="service-icon-wrapper">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#0040A5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              <line x1="9" y1="12" x2="15" y2="12"/>
              <line x1="12" y1="9" x2="12" y2="15"/>
            </svg>
          </div>
          <h3 class="service-name">Private Vaccination</h3>
          <p class="service-desc"><%= settings.service_pvt_desc || 'Paid specialized immunization schedules, cervical cancer prevention, international travel vaccines, and adult boosters.' %></p>
          <button class="learn-more-btn" id="openPvtVaxModal">
            Learn More
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="arrow-icon">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </button>
        </div>

        <!-- Service Card 2 -->
        <div class="service-card" data-service-id="family-planning">
          <div class="card-badge">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <div class="service-icon-wrapper">
            <% if (settings.service_fp_image) { %>
              <img src="<%= settings.service_fp_image %>" alt="Family Planning" class="service-icon-img">
            <% } else { %>
            <!-- Family/People Icon -->
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#0040A5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
            <% } %>
          </div>
          <h3 class="service-name">Family Planning</h3>
          <p class="service-desc"><%= settings.service_fp_desc %></p>
          <button class="learn-more-btn" data-service="family-planning">
            Learn More 
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="arrow-icon">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </button>
        </div>

        <!-- Service Card 3 -->
        <div class="service-card" data-service-id="antenatal">
          <div class="card-badge">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <div class="service-icon-wrapper">
            <% if (settings.service_anc_image) { %>
              <img src="<%= settings.service_anc_image %>" alt="Antenatal Care" class="service-icon-img">
            <% } else { %>
            <!-- Pregnant Woman/Baby Care Icon -->
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#0040A5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="5" r="2"/>
              <path d="M12 7c-1.5 0-3 1-3 3v5c0 2.5 1.5 4.5 3.5 5.5l.5.5.5-.5c2-1 3.5-3 3.5-5.5v-5c0-2-1.5-3-3-3z"/>
              <path d="M9 11.5c.5.5 1.5.5 2 0L12 11l1 .5c.5.5 1.5.5 2 0"/>
            </svg>
            <% } %>
          </div>
          <h3 class="service-name">Antenatal Care</h3>
          <p class="service-desc"><%= settings.service_anc_desc %></p>
          <button class="learn-more-btn" data-service="antenatal">
            Learn More 
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="arrow-icon">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </button>
        </div>

        <!-- Service Card 4 -->
        <div class="service-card" data-service-id="autism">
          <div class="card-badge">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <div class="service-icon-wrapper">
            <% if (settings.service_autism_image) { %>
              <img src="<%= settings.service_autism_image %>" alt="Autism Support" class="service-icon-img">
            <% } else { %>
            <!-- Puzzle Piece Icon -->
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#0040A5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M19 10a3 3 0 0 0-3-3h-1V6a3 3 0 0 0-6 0v1H8a3 3 0 0 0-3 3v1H4a3 3 0 0 0 0 6h1v1a3 3 0 0 0 3 3h1a3 3 0 0 0 6 0v-1h1a3 3 0 0 0 3-3v-1a3 3 0 0 0 0-6h-1v-1z"/>
            </svg>
            <% } %>
          </div>
          <h3 class="service-name">Autism Support</h3>
          <p class="service-desc"><%= settings.service_autism_desc %></p>
          <button class="learn-more-btn" data-service="autism">
            Learn More 
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="arrow-icon">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- Interactive Vaccination Schedules Section -->
  <section class="schedule-section" id="schedules">
    <div class="container">
      <div class="section-header text-center">
        <span class="section-tag">Immunization Timelines</span>
        <h2 class="section-title">EPI Vaccination Schedules</h2>
        <p class="section-subtitle">Keep track of crucial vaccine dates. Enter your child's Date of Birth below to check their exact immunization timeline based on the official Bangladesh Government guidelines.</p>
      </div>

      <div class="schedule-calculator-card">
        <div class="calc-form">
          <div class="form-group">
            <label class="dob-main-label" for="dobTrigger">Child's Date of Birth</label>
            <div class="input-with-btn">
              <div class="dob-trigger-wrap">
                <button type="button" class="dob-trigger" id="dobTrigger" aria-haspopup="true" aria-expanded="false">
                  <span id="dobTriggerText" class="dob-trigger-placeholder">dd/mm/yyyy</span>
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="16" y1="2" x2="16" y2="6"/></svg>
                </button>
                <div class="dob-popup hidden" id="dobCalendarPopup" role="dialog" aria-label="Date picker">
                  <div id="dobCalendarWidget" class="dob-calendar-wrap"></div>
                </div>
              </div>
              <button class="btn btn-primary" id="calcScheduleBtn">Calculate Schedule</button>
            </div>
          </div>
        </div>

        <div class="calc-results hidden" id="calcResults">
          <h3 class="results-title">Calculated Immunization Timeline</h3>
          <div class="timeline-table-wrapper">
            <table class="timeline-table">
              <thead>
                <tr>
                  <th>Vaccine & Dose</th>
                  <th>Target Age</th>
                  <th>Recommended Date</th>
                  <th>Prevention/Diseases</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody id="timelineTableBody">
                <!-- Filled via JS -->
              </tbody>
            </table>
          </div>
          <div class="timeline-note">
            <p><strong>Note:</strong> This timeline is based on the national Expanded Programme on Immunization (EPI) guidelines in Bangladesh. Please consult with our health workers during immunization sessions to confirm vaccine administration.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Resources Section -->
  <section class="resources-section" id="resources">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Resources</span>
        <h2 class="section-title">Health Resources & Publications</h2>
      </div>
      <% if (resources && resources.length) { %>
      <div class="resources-grid">
        <% resources.forEach(function(res) { %>
        <div class="resource-card">
          <div class="resource-type"><%= res.type || 'GUIDE' %></div>
          <h3><%= res.title %></h3>
          <% if (res.description) { %><p><%= res.description %></p><% } %>
          <div class="resource-actions">
            <% if (res.file_path) { %>
              <a href="<%= res.file_path %>" target="_blank" rel="noopener noreferrer" class="resource-link">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                View
              </a>
              <a href="/api/resources/<%= res.id %>/download" class="resource-link-dl">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                Download
              </a>
            <% } else { %>
              <span class="resource-link resource-link-unavailable">File Coming Soon</span>
            <% } %>
          </div>
        </div>
        <% }) %>
      </div>
      <% } else { %>
      <p style="color:var(--color-text-muted);text-align:center;padding:40px 0">No resources published yet.</p>
      <% } %>
    </div>
  </section>

  <!-- Custom Content Sections (managed via Admin Dashboard) -->
  <% sections.forEach((section, idx) => { %>
  <section class="custom-section <%= idx % 2 === 1 ? 'custom-section-reverse' : '' %>">
    <div class="container custom-section-grid">
      <% if (section.image_path) { %>
      <div class="custom-section-image">
        <img src="<%= section.image_path %>" alt="<%= section.title %>">
      </div>
      <% } %>
      <div class="custom-section-content">
        <h2 class="section-title"><%= section.title %></h2>
        <p><%- section.content %></p>
      </div>
    </div>
  </section>
  <% }) %>

  <!-- Events Section -->
  <section class="events-preview-section" id="events">
    <div class="container">
      <div class="section-header text-center">
        <span class="section-tag">Programs & Outreach</span>
        <h2 class="section-title">Upcoming Events</h2>
        <p class="section-subtitle">Health camps, vaccination drives, seminars and community programs organized by Bliss Bangladesh.</p>
      </div>
      <div class="events-preview-grid" id="eventsPreviewGrid">
        <div class="events-loading">Loading events...</div>
      </div>
      <div class="text-center" style="margin-top:36px;">
        <a href="/events" class="btn btn-primary">View All Events</a>
      </div>
    </div>
  </section>

  <!-- Contact Section (Includes interactive form) -->
  <%
    var _socials = [
      { key:'social_facebook',  label:'Facebook',  color:'#1877F2', icon:'<path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>' },
      { key:'social_linkedin',  label:'LinkedIn',  color:'#0A66C2', icon:'<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>' },
      { key:'social_twitter',   label:'Twitter / X', color:'#000', icon:'<line x1="4" y1="4" x2="20" y2="20"/><line x1="20" y1="4" x2="4" y2="20"/>' },
      { key:'social_instagram', label:'Instagram', color:'#E1306C', icon:'<rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>' },
      { key:'social_youtube',   label:'YouTube',   color:'#FF0000', icon:'<path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.96-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/>' },
      { key:'social_tiktok',    label:'TikTok',    color:'#010101', icon:'<path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/>' },
    ];
    var _activeSocials = _socials.filter(function(s){ return settings[s.key] && settings[s.key].trim(); });
  %>

  <section class="contact-section" id="contact">
    <div class="container">
      <div class="contact-grid">
        <!-- Contact Information -->
        <div class="contact-info-panel">
          <span class="section-tag">Get in Touch</span>
          <h2 class="section-title">We are Here to Help You</h2>
          <p>Have questions about immunization, family planning methods, or scheduling a consultant? Leave us a message or visit us directly.</p>
          
          <div class="contact-details-list">
            <div class="contact-detail-item">
              <div class="detail-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
              </div>
              <div>
                <h4>Our Center Location</h4>
                <p><%= settings.contact_address %></p>
              </div>
            </div>
            <div class="contact-detail-item">
              <div class="detail-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                  <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                  <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
                </svg>
              </div>
              <div>
                <h4>Social Presence</h4>
                <% if (_activeSocials.length > 0) { %>
                <div style="display:flex;flex-wrap:wrap;gap:10px;margin-top:10px">
                  <% _activeSocials.forEach(function(s){ %>
                  <a href="<%= settings[s.key] %>" target="_blank" rel="noopener noreferrer"
                     title="<%= s.label %>"
                     style="display:inline-flex;align-items:center;gap:7px;padding:7px 14px;border-radius:20px;background:<%= s.color %>;color:#fff;text-decoration:none;font-size:0.8rem;font-weight:600;font-family:var(--font-body);transition:opacity .15s"
                     onmouseover="this.style.opacity='.82'" onmouseout="this.style.opacity='1'">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><%- s.icon %></svg>
                    <%= s.label %>
                  </a>
                  <% }); %>
                </div>
                <% } else { %>
                <p style="margin:6px 0 0;color:var(--color-muted);font-size:.84rem">Follow us on social media.</p>
                <% } %>
              </div>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="contact-form-panel">
          <h3>Send a Quick Inquiry</h3>
          <form id="contactForm" class="contact-form">
            <div class="form-row">
              <div class="form-group">
                <label for="contactName">Your Name *</label>
                <input type="text" id="contactName" required class="form-control" placeholder="Enter name">
              </div>
              <div class="form-group">
                <label for="contactEmail">Email Address</label>
                <input type="email" id="contactEmail" class="form-control" placeholder="Enter email">
              </div>
            </div>
            <div class="form-group">
              <label for="contactPhone">Phone Number *</label>
              <input type="tel" id="contactPhone" required class="form-control" placeholder="e.g. 017XXXXXXXX">
            </div>
            <div class="form-group">
              <label for="contactMessage">Your Message *</label>
              <textarea id="contactMessage" rows="4" required class="form-control" placeholder="How can we assist you?"></textarea>
            </div>
            <button type="submit" class="btn btn-primary btn-block">Submit Message</button>
            <div class="form-feedback hidden" id="contactFeedback"></div>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer Stats Banner -->
  <section class="footer-banner">
    <div class="container footer-banner-grid">
      <!-- Visit Us -->
      <div class="footer-banner-item">
        <div class="footer-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
        </div>
        <div class="footer-text">
          <h5>Visit Us</h5>
          <p><%= settings.contact_address %></p>
        </div>
