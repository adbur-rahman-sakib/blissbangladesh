  <!-- Main Footer -->
  <footer class="footer-main">
    <div class="container text-center">
      <p>&copy; 2026 Bliss Bangladesh. All rights reserved. Government Authorized EPI & Family Planning Center.</p>
    </div>
  </footer>

  <!-- Booking Modal -->
  <div class="modal-overlay hidden" id="bookingModal">
    <div class="modal-container">
      <button class="modal-close" id="closeBookingBtn">&times;</button>
      <div class="modal-header">
        <h3>Book an Appointment</h3>
        <p>Schedule your immunization or consultation slot. We will confirm your timing via SMS.</p>
      </div>
      <form id="bookingForm" class="modal-form">
        <div class="form-group">
          <label for="bookName">Patient's Full Name *</label>
          <input type="text" id="bookName" required class="form-control" placeholder="Enter name">
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="bookPhone">Contact Phone Number *</label>
            <input type="tel" id="bookPhone" required class="form-control" placeholder="e.g. 017XXXXXXXX">
          </div>
          <div class="form-group">
            <label for="bookDobTrigger">Date of Birth</label>
            <div class="dob-trigger-wrap">
              <button type="button" class="dob-trigger" id="bookDobTrigger" aria-haspopup="true" aria-expanded="false">
                <span id="bookDobTriggerText" class="dob-trigger-placeholder">Select date of birth</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              </button>
              <div class="dob-popup hidden" id="bookDobPopup">
                <div id="bookDobWidget" class="dob-calendar-wrap"></div>
              </div>
            </div>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="bookService">Select Service Required *</label>
            <select id="bookService" required class="form-control">
              <option value="" disabled selected>Select service</option>
              <option value="EPI Vaccination">EPI Vaccination</option>
              <option value="Family Planning">Family Planning Consultation</option>
              <option value="Antenatal Care">Antenatal Care Checkup</option>
              <option value="Autism Support">Autism Support & Therapy</option>
            </select>
          </div>
          <div class="form-group">
            <label for="bookDateTrigger">Preferred Appointment Date *</label>
            <div class="dob-trigger-wrap">
              <button type="button" class="dob-trigger" id="bookDateTrigger" aria-haspopup="true" aria-expanded="false">
                <span id="bookDateTriggerText" class="dob-trigger-placeholder">Select appointment date</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              </button>
              <div class="dob-popup hidden" id="bookDatePopup">
                <div id="bookDateWidget" class="dob-calendar-wrap"></div>
              </div>
            </div>
          </div>
        </div>
        <div class="form-group">
          <label for="bookTime">Preferred Time Slot *</label>
          <select id="bookTime" required class="form-control">
            <option value="" disabled selected>Select slot</option>
            <option value="09:00 AM - 11:00 AM">Morning (09:00 AM - 11:00 AM)</option>
            <option value="11:00 AM - 01:00 PM">Midday (11:00 AM - 01:00 PM)</option>
            <option value="02:00 PM - 04:00 PM">Afternoon (02:00 PM - 04:00 PM)</option>
            <option value="04:00 PM - 06:00 PM">Late Afternoon (04:00 PM - 06:00 PM)</option>
          </select>
        </div>
        <button type="submit" class="btn btn-primary btn-block">Confirm Appointment Request</button>
      </form>

      <!-- Booking Success Screen -->
      <div class="modal-success-state hidden" id="bookingSuccess">
        <div class="success-icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#4CAF50" stroke-width="2.5">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="22 4 12 14.01 9 11.01"/>
          </svg>
        </div>
        <h3>Booking Request Received!</h3>
        <p class="success-msg">Thank you, <strong id="successPatientName"></strong>. We have logged your request for <strong id="successServiceName"></strong> on <strong id="successDate"></strong>.</p>
        <p class="success-note">A confirmation SMS has been sent to <span id="successPhone"></span>. Please arrive 10 minutes prior to your slot.</p>
        <button class="btn btn-primary" id="closeSuccessBtn">Close Window</button>
      </div>
    </div>
  </div>

