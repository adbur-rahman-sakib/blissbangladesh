  <!-- Private Vaccine Schedule Modal -->
  <div class="modal-overlay hidden" id="pvtVaxModal">
    <div class="pvt-modal-container">
      <div class="pvt-modal-header">
        <div class="pvt-modal-title-group">
          <div class="pvt-modal-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#0040A5" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              <line x1="9" y1="12" x2="15" y2="12"/>
              <line x1="12" y1="9" x2="12" y2="15"/>
            </svg>
          </div>
          <div>
            <h3>Private Vaccine Schedule</h3>
            <p>Paid immunization programs available at Bliss Bangladesh</p>
          </div>
        </div>
        <button class="modal-close" id="closePvtVaxModal">&times;</button>
      </div>

      <div class="pvt-modal-search">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#94A3B8" stroke-width="2.5" stroke-linecap="round" class="pvt-search-icon">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input type="text" id="pvtVaxSearch" class="pvt-search-input" placeholder="Search vaccine name or disease...">
